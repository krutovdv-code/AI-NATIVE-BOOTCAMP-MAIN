{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/legal\\/consent-marketing\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/legal\\/cookies\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/legal\\/oferta\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/legal\\/privacy\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/legal\\/terms\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/notboring\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/spasibo\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}