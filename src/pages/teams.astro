<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; border-radius: 0 !important; }

  :root {
    --bg: #f5f5f0;
    --ink: #0a0a0f;
    --accent: #f5a623;
    --ink10: rgba(10,10,15,0.10);
    --ink20: rgba(10,10,15,0.20);
    --ink40: rgba(10,10,15,0.40);
    --ink60: rgba(10,10,15,0.60);
    --ink05: rgba(10,10,15,0.05);
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
    font-variant-numeric: tabular-nums;
    text-rendering: optimizeLegibility;
    max-width: 1440px;
    margin: 0 auto;
    overflow-x: hidden;
  }

  h1, h2, h3, .display {
    font-family: 'Roboto Condensed', 'Arial Narrow', Arial, sans-serif !important;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  /* TOP BAR */
  .t-topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 48px;
    background: rgba(245,245,240,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--ink10);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    max-width: 1440px;
    margin: 0 auto;
  }
  .t-topbar__logo {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--ink);
    cursor: pointer;
    transition: color 0.15s;
  }
  .t-topbar__logo:hover { color: var(--accent); }
  .t-topbar__back {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink40);
    text-decoration: none;
    transition: color 0.15s;
  }
  .t-topbar__back:hover { color: var(--ink); }
  .t-topbar__tag {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
  }

  /* SECTIONS */
  section {
    padding: 80px 24px;
    border-bottom: 1px solid var(--ink10);
    position: relative;
  }
  .t-wrap { max-width: 1200px; margin: 0 auto; width: 100%; }

  /* TYPOGRAPHY */
  .t-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 24px;
    display: block;
  }
  .t-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(32px, 4vw, 56px);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: 40px;
  }
  .t-title .accent { color: var(--accent); }
  .t-prose {
    font-size: 14px;
    line-height: 1.8;
    color: var(--ink60);
    max-width: 720px;
    margin-bottom: 32px;
  }
  .t-prose strong { color: var(--ink); font-weight: 600; }

  /* HERO */
  #t-hero {
    padding: 120px 24px 80px;
    min-height: 60vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-bottom: 1px solid var(--ink10);
    background: var(--ink);
  }
  .t-hero__label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 24px;
    display: block;
  }
  .t-hero__title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(48px, 7vw, 100px);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.92;
    color: rgba(245,245,240,1);
    margin-bottom: 40px;
    max-width: 1000px;
  }
  .t-hero__title .accent { color: var(--accent); }
  .t-hero__sub {
    border-left: 2px solid var(--accent);
    padding-left: 24px;
    max-width: 600px;
    font-size: 13px;
    line-height: 1.7;
    color: rgba(245,245,240,0.55);
  }

  /* 3-COLUMN GRID (проблема, результат, клуб) */
  .t-grid3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .t-cell {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
  }
  .t-cell:last-child { border-right: none; }
  .t-cell__num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 36px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .t-cell__title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .t-cell__text {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .t-cell__text strong { color: var(--ink); }
  @media (max-width: 768px) {
    .t-grid3 { grid-template-columns: 1fr; }
    .t-cell { border-right: none; border-bottom: 1px solid var(--ink10); }
    .t-cell:last-child { border-bottom: none; }
  }

  /* RESULT ROWS */
  .t-result-stack { display: flex; flex-direction: column; gap: 0; }
  .t-result-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 32px;
    padding: 28px 32px;
    border: 1px solid var(--ink10);
    border-bottom: none;
    background: var(--ink05);
  }
  .t-result-row:last-child { border-bottom: 1px solid var(--ink10); }
  .t-result-row--featured {
    background: var(--ink);
    border-color: var(--ink);
  }
  .t-result-tag {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-weight: 500;
    padding-top: 3px;
  }
  .t-result-h {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 20px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .t-result-row--featured .t-result-h { color: rgba(245,245,240,1); }
  .t-result-row--featured .t-result-h .accent { color: var(--accent); }
  .t-result-d {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .t-result-row--featured .t-result-d { color: rgba(245,245,240,0.55); }
  @media (max-width: 640px) {
    .t-result-row { grid-template-columns: 1fr; gap: 8px; padding: 20px; }
  }

  /* SCALING GRID */
  .t-scale-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .t-scale-cell {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    background: var(--ink05);
  }
  .t-scale-cell:nth-child(2n) { border-right: none; }
  .t-scale-cell:nth-last-child(-n+2) { border-bottom: none; }
  .t-scale-tag {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    display: block;
    margin-bottom: 10px;
  }
  .t-scale-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .t-scale-text {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }
  @media (max-width: 640px) {
    .t-scale-grid { grid-template-columns: 1fr; }
    .t-scale-cell { border-right: none; }
    .t-scale-cell:nth-last-child(-n+2) { border-bottom: 1px solid var(--ink10); }
    .t-scale-cell:last-child { border-bottom: none; }
  }

  /* CLUB BANNER */
  .t-club-banner {
    background: var(--ink);
    padding: 32px 36px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: center;
    margin-bottom: 2px;
  }
  .t-club-banner__tag {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 8px;
    display: block;
  }
  .t-club-banner__h {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(22px, 2.5vw, 32px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.95;
    color: rgba(245,245,240,1);
  }
  .t-club-banner__h .accent { color: var(--accent); }
  .t-club-banner__num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 72px;
    color: var(--accent);
    letter-spacing: -0.04em;
    line-height: 0.85;
    text-align: center;
  }
  .t-club-banner__num-lab {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.12em;
    color: rgba(245,245,240,0.5);
    font-weight: 500;
    text-transform: uppercase;
    margin-top: 6px;
    text-align: center;
  }
  @media (max-width: 640px) {
    .t-club-banner { grid-template-columns: 1fr; gap: 20px; padding: 24px 20px; }
    .t-club-banner__num { font-size: 56px; text-align: left; }
    .t-club-banner__num-lab { text-align: left; }
  }

  /* CTA BUTTON */
  .cta-btn {
    display: inline-block;
    position: relative;
    overflow: hidden;
    padding: 16px 40px;
    background: var(--accent);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    cursor: pointer;
    border: none;
  }
  .cta-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }
  .cta-btn:hover::before { transform: translateX(0); }
  .cta-btn span { position: relative; z-index: 1; }
  .cta-btn:hover span { color: #f5f5f0; }

  /* CTA SECTION */
  #t-cta {
    background: var(--ink);
    border-bottom: none;
  }
  .t-cta__title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(28px, 4vw, 52px);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: rgba(245,245,240,1);
    margin-bottom: 16px;
  }
  .t-cta__title .accent { color: var(--accent); }
  .t-cta__sub {
    font-size: 13px;
    line-height: 1.7;
    color: rgba(245,245,240,0.45);
    margin-bottom: 36px;
    max-width: 560px;
  }

  /* WIDGET MODAL */
  .widget-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(10,10,15,0.7);
    backdrop-filter: blur(6px);
    align-items: center;
    justify-content: center;
  }
  .widget-modal.is-open { display: flex; }
  .widget-modal__box {
    background: var(--bg);
    width: min(560px, calc(100vw - 32px));
    max-height: calc(100vh - 64px);
    overflow: auto;
    position: relative;
    padding: 32px;
  }
  .widget-modal__close {
    position: absolute;
    top: 12px; right: 16px;
    background: none; border: none;
    font-size: 22px;
    cursor: pointer;
    color: var(--ink40);
    line-height: 1;
  }
  .widget-modal__close:hover { color: var(--ink); }

  /* FOOTER */
  .t-footer {
    padding: 24px;
    border-top: 1px solid var(--ink10);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink40);
  }
  .t-footer a { color: var(--ink40); text-decoration: none; }
  .t-footer a:hover { color: var(--ink); }

  /* ── NEW B2B SECTIONS ── */

  /* 2-column grid */
  .t-grid2 { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid var(--ink10); margin-top: 32px; }
  .t-grid2 .t-cell { padding: 28px 32px; border-right: 1px solid var(--ink10); background: var(--ink05); }
  .t-grid2 .t-cell:last-child { border-right: none; }

  /* 2×2 grid (симптомы) */
  .t-grid2x2 { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid var(--ink10); margin-top: 32px; }
  .t-grid2x2 .t-cell { padding: 28px 32px; border-right: 1px solid var(--ink10); border-bottom: 1px solid var(--ink10); background: var(--ink05); }
  .t-grid2x2 .t-cell:nth-child(2n) { border-right: none; }
  .t-grid2x2 .t-cell:nth-last-child(-n+2) { border-bottom: none; }

  /* Cell tag (мелкий оранжевый лейбл внутри ячейки) */
  .t-cell__tag { font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); font-family: 'JetBrains Mono', monospace; margin-bottom: 8px; display: block; }

  /* Callout — левая оранжевая рамка */
  .t-callout { border-left: 3px solid var(--accent); padding-left: 20px; font-size: 14px; line-height: 1.6; color: var(--ink); margin-bottom: 24px; }

  /* Highlight-строка */
  .t-highlight { padding: 16px 20px; background: var(--ink05); border-left: 3px solid var(--accent); font-size: 13px; line-height: 1.6; margin-top: 24px; }

  /* Двухколонный список */
  .t-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 24px; }
  .t-col-head { font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--ink10); }
  .t-blist { list-style: none; }
  .t-blist li { font-size: 13px; line-height: 1.7; color: var(--ink60); padding-left: 16px; position: relative; margin-bottom: 12px; }
  .t-blist li::before { content: ''; position: absolute; left: 0; top: 8px; width: 5px; height: 5px; background: var(--accent); }

  /* Таблица пакетов */
  .t-pkg-table { border: 1px solid var(--ink10); margin: 32px 0 0; }
  .t-pkg-hdr { display: grid; grid-template-columns: repeat(3, 1fr); border-bottom: 1px solid var(--ink10); }
  .t-pkg-hdr-cell { padding: 16px 20px; border-right: 1px solid var(--ink10); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; font-family: 'Roboto Condensed', sans-serif; }
  .t-pkg-hdr-cell:last-child { border-right: none; }
  .t-pkg-hdr-cell .sub { display: block; font-size: 10px; font-weight: 400; color: var(--ink40); text-transform: none; letter-spacing: 0; margin-top: 4px; font-family: 'JetBrains Mono', monospace; }
  .t-pkg-body { display: grid; grid-template-columns: repeat(3, 1fr); }
  .t-pkg-col { border-right: 1px solid var(--ink10); padding: 16px 20px; display: flex; flex-direction: column; gap: 8px; }
  .t-pkg-col:last-child { border-right: none; }
  .t-pkg-item { font-size: 11px; line-height: 1.6; color: var(--ink60); padding: 8px 10px; }
  .t-pkg-item.accent { background: var(--ink05); color: var(--ink); font-weight: 600; border-left: 2px solid var(--accent); }

  /* Ценовой баннер */
  .t-price-banner { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; background: var(--ink); margin-top: 24px; flex-wrap: wrap; gap: 12px; }
  .t-price-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(245,245,240,0.5); }
  .t-price-value { font-family: 'Roboto Condensed', sans-serif !important; font-weight: 900; font-size: 28px; color: var(--accent); letter-spacing: -0.02em; }
  .t-price-note { font-size: 11px; color: rgba(245,245,240,0.4); }

  /* Контакты в CTA */
  .t-contacts { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid rgba(245,245,240,0.15); margin-top: 32px; max-width: 480px; }
  .t-contact-cell { padding: 16px 20px; border-right: 1px solid rgba(245,245,240,0.15); }
  .t-contact-cell:last-child { border-right: none; }
  .t-contact-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(245,245,240,0.4); margin-bottom: 6px; }
  .t-contact-value { font-family: 'Roboto Condensed', sans-serif !important; font-weight: 900; font-size: 18px; text-transform: uppercase; color: var(--bg); letter-spacing: -0.01em; }

  /* Адаптив новых компонентов */
  @media (max-width: 768px) {
    .t-grid2, .t-grid2x2, .t-two-col { grid-template-columns: 1fr; }
    .t-grid2 .t-cell, .t-grid2x2 .t-cell { border-right: none; border-bottom: 1px solid var(--ink10); }
    .t-grid2 .t-cell:last-child { border-bottom: none; }
    .t-pkg-hdr, .t-pkg-body { grid-template-columns: 1fr; }
    .t-pkg-hdr-cell { border-right: none; border-bottom: 1px solid var(--ink10); }
    .t-pkg-hdr-cell:last-child { border-bottom: none; }
    .t-pkg-col { border-right: none; border-bottom: 1px solid var(--ink10); }
    .t-pkg-col:last-child { border-bottom: none; }
    .t-price-banner { flex-direction: column; align-items: flex-start; }
    .t-contacts { grid-template-columns: 1fr; }
    .t-contact-cell { border-right: none; border-bottom: 1px solid rgba(245,245,240,0.15); }
    .t-contact-cell:last-child { border-bottom: none; }
  }
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="t-topbar">
  <a href="/" class="t-topbar__logo">NA\\TION</a>
  <span class="t-topbar__tag">// ДЛЯ КОМАНД</span>
  <a href="/" class="t-topbar__back">← На главную</a>
</div>

<!-- HERO -->
<section id="t-hero">
  <div class="t-wrap">
    <span class="t-hero__label">[BOOTCAMP_B2B] // AI-DRIVEN DEVELOPMENT</span>
    <h1 class="t-hero__title">
      AI-Driven Bootcamp<br>
      для <span class="accent">инженерных команд</span>
    </h1>
    <div class="t-hero__sub">
      <p style="margin-bottom:12px;">Апгрейд роли разработчика и представителей продуктовых команд IT</p>
      <p>Трансформация компаний через встраивание AI в реальные процессы компании</p>
    </div>
    <div style="margin-top:40px;">
      <button type="button" class="cta-btn js-open-widget-teams"><span>→ Обсудить условия</span></button>
    </div>
  </div>
</section>

<!-- VISION -->
<section id="t-vision">
  <div class="t-wrap">
    <span class="t-label">[ВИДЕНИЕ] // AI-DRIVEN — ЭТО НОВЫЙ СТАНДАРТ</span>
    <h2 class="t-title">Рынок переходит<br>к <span class="accent">AI-driven</span> компаниям</h2>
    <div class="t-callout">AI-driven — это новый стандарт конкурентоспособности, а не модный эксперимент</div>
