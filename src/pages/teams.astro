<script is:inline>
  // Widget modal
  var teamsModal = document.getElementById('widget-modal-teams');
  var teamsWidgetBody = document.getElementById('widget-modal-teams-body');
  var teamsWidgetLoaded = false;

  function openTeamsModal() {
    if (!teamsModal) return;
    if (!teamsWidgetLoaded && teamsWidgetBody) {
      teamsWidgetLoaded = true;
      var s = document.createElement('script');
      s.setAttribute('ao-number', '3272');
      s.setAttribute('ao-widget-id', 'Pex42y1uHUWMJNatz8smDA');
      s.setAttribute('ao-domain', 'content.scalingclub.ru');
      s.src = 'https://idx.xl.ru/site/widget/widget.min.js';
      s.async = true;
      teamsWidgetBody.appendChild(s);
    }
    teamsModal.classList.add('is-open');
    teamsModal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeTeamsModal() {
    if (teamsModal) {
      teamsModal.classList.remove('is-open');
      teamsModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  }

  document.querySelectorAll('.js-open-widget-teams').forEach(function(btn) {
    btn.addEventListener('click', function(e) { e.preventDefault(); openTeamsModal(); });
  });
  document.querySelectorAll('.js-close-widget-teams').forEach(function(btn) {
    btn.addEventListener('click', closeTeamsModal);
  });
  if (teamsModal) {
    teamsModal.addEventListener('click', function(e) {
      if (e.target === teamsModal) closeTeamsModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && teamsModal.classList.contains('is-open')) closeTeamsModal();
    });
  }
</script>

