    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }
  .feedback-placeholder-icon {
    font-size: 24px;
    color: var(--ink20);
    line-height: 1;
  }
  .feedback-placeholder-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink20);
  }
