const whyTabs: Tab[] = [
  {
    n: "1",
    label: "Рынок меняется прямо сейчас",
    title: "Рынок меняется прямо сейчас",
    items: [
      {
        h: "Четверть команд сообщают о трансформации",
        t: "По данным Deloitte State of AI in the Enterprise 2026, доля лидеров, сообщающих о трансформирующем эффекте AI на их компании, за год выросла более чем вдвое и достигла 25%.",
        url: "https://www.deloitte.com/us/en/about/press-room/state-of-ai-report-2026.html",
      },
      {
        h: "Новые профессии растут быстрее старых",
        t: "Спрос на forward deployed engineers и похожие роли вырос в 42 раза с 2023 по 2025 год, а AI engineer стал самой быстрорастущей профессией в США в 2026 году.",
        url: "https://www.linkedin.com/pulse/linkedin-jobs-rise-2026-25-fastest-growing-roles-us-linkedin-news-dlb1c",
      },
      {
        h: "Технологические гиганты перестраивают штат",
        t: "В мае и июне 2026 года OpenAI, Anthropic, AWS и Databricks за шесть недель вложили более 6,5 млрд долларов в отдельные подразделения forward deployed engineering, закрепив эту роль на уровне крупнейших технологических компаний мира.",
        url: "https://techcrunch.com/2026/05/04/anthropic-and-openai-are-both-launching-joint-ventures-for-enterprise-ai-services/",
      },
    ],
  },
  {
    n: "2",
    label: "Мы в эпицентре этого сдвига",
    title: "Мы в эпицентре этого сдвига",
    intro: [
      "Рост доли продуктовых задач не означает, что появится только одна профессия. Внутри этого сдвига уже появляются конкретные новые роли, AI-инженер, forward deployed engineer, продуктовый инженер, и список будет меняться дальше.",
      "Разбираться в таком потоке проще рядом с людьми, которые сами в нём работают.",
    ],
    bullets: [
      "Михаил Овчинников — staff-инженер в Google",
      "Николай Барышников работал в Yandex Cloud и сейчас является AI-архитектором в собственном проекте",
      "Даниил Пилипенко как CEO SymbioWay сам нанимает специалистов на такие роли и каждый день имеет дело с тем, как эти требования меняются",
    ],
    outro: "Материалов такого уровня погружения на русском языке крайне мало.",
    cta: { label: "Подробнее про авторов", href: "#committee" },
  },
  {
    n: "3",
    label: "Почему не учиться самому?",
    title: "Самостоятельное обучение может привести не туда",
    items: [
      {
        h: "Промт-инженеринг устарел за полгода",
        t: "Ещё недавно многие вкладывались в отдельную специализацию по промт-инженерингу как в самостоятельную профессию. Сегодня бизнесу это почти не нужно само по себе, инструменты изменились быстрее, чем успел закрепиться навык. Тот же риск сейчас стоит перед контекст-инженерингом и другими узкими практиками, которые на слуху именно в этом году.",
      },
      {
        h: "Без ориентира легко потратить время впустую",
        t: "Ролики и статьи в открытом доступе рассказывают о конкретных приёмах, но редко объясняют, что из этого нужно рынку. Без фильтра легко потратить месяцы на инструмент, который через полгода станет нерелевантным. Буткемп даёт набор инструментов и навыков, собранных людьми, которые каждый день используют AI в коммерческих проектах.",
      },
      {
        h: "Практика с обратной связью закрепляет навык",
        t: "Знание, полученное без проверки, легко забывается или применяется неверно. На буткемпе каждая практика разбирается с командой и не уходит «в стол». Портфолио и обратная связь фиксируют навык в рабочем виде, который можно показать работодателю или применить в задачах уже сейчас.",
      },
    ],
  },
];
