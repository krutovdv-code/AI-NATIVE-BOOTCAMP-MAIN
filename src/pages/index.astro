<script is:inline>
  // Включаем анимации только при работающем JS (без JS контент уже виден по умолчанию)
  document.documentElement.classList.add('js');
  // Счётчики не сбрасываем тут — в HTML уже 12, 14, 5, 2x; в 0 поставим только при запуске анимации в observer

  // Модальное окно с виджетом заявки (виджет подгружаем при первом открытии — не блокирует страницу)
  const modal = document.getElementById('widget-modal');
  const widgetBody = document.getElementById('widget-modal-body');
  var widgetLoaded = false;
  function openWidgetModal() {
    if (!modal) return;
    if (!widgetLoaded && widgetBody) {
      widgetLoaded = true;
      var s = document.createElement('script');
      s.setAttribute('ao-number', '3272');
      s.setAttribute('ao-widget-id', 'Pex42y1uHUWMJNatz8smDA');
      s.setAttribute('ao-domain', 'content.scalingclub.ru');
      s.src = 'https://idx.xl.ru/site/widget/widget.min.js';
      s.async = true;
      widgetBody.appendChild(s);
    }
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeWidgetModal() {
    if (modal) {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  }
  document.querySelectorAll('.js-open-widget').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      closeBurger();
      openWidgetModal();
    });
  });
  document.querySelectorAll('.js-close-widget').forEach(function(btn) {
    btn.addEventListener('click', closeWidgetModal);
  });
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeWidgetModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeWidgetModal();
    });
  }

  // Hero word reveal
  window.addEventListener('load', () => {
    const words = document.querySelectorAll('.hero-title .word');
    words.forEach((w, i) => {
      setTimeout(() => w.classList.add('visible'), 200 + i * 70);
    });
  });

  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        // Stagger children
        const children = e.target.querySelectorAll('.audience-item, .learn-item, .format-item, .faq-item');
        children.forEach((c, i) => {
          setTimeout(() => c.classList.add('visible'), i * 80);
        });
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal, .module-block').forEach(el => observer.observe(el));

  // Counter animation
  function animateCounter(el) {
    const target = parseInt(el.dataset.target);
    const suffix = el.dataset.suffix || '';
    let current = 0;
    const step = target / 30;
    const timer = setInterval(() => {
      current += step;
      if (current >= target) { current = target; clearInterval(timer); }
      el.textContent = Math.floor(current) + suffix;
    }, 40);
  }

  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const els = e.target.querySelectorAll('[data-target]');
        els.forEach(el => { el.textContent = '0'; });
        els.forEach(animateCounter);
        statsObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.5 });

  const statsEl = document.querySelector('.hero-stats');
  if (statsEl) statsObserver.observe(statsEl);

  // Бургер-меню: открыть/закрыть
  var burgerBtn = document.querySelector('.js-burger-toggle');
  var burgerOverlay = document.getElementById('burger-overlay');
  function openBurger() {
    if (burgerOverlay) {
      burgerOverlay.classList.add('is-open');
      burgerOverlay.setAttribute('aria-hidden', 'false');
      if (burgerBtn) { burgerBtn.classList.add('is-open'); burgerBtn.setAttribute('aria-expanded', 'true'); }
      document.body.style.overflow = 'hidden';
    }
  }
  function closeBurger() {
    if (burgerOverlay) {
      burgerOverlay.classList.remove('is-open');
      burgerOverlay.setAttribute('aria-hidden', 'true');
      if (burgerBtn) { burgerBtn.classList.remove('is-open'); burgerBtn.setAttribute('aria-expanded', 'false'); }
      document.body.style.overflow = '';
    }
  }
  if (burgerBtn) burgerBtn.addEventListener('click', function() {
    if (burgerOverlay && burgerOverlay.classList.contains('is-open')) closeBurger();
    else openBurger();
  });
  if (burgerOverlay) burgerOverlay.addEventListener('click', function(e) {
    if (e.target === burgerOverlay) closeBurger();
  });
  document.querySelectorAll('.js-burger-link').forEach(function(link) {
    link.addEventListener('click', function(e) {
      var href = this.getAttribute('href');
      if (href && href[0] === '#') {
        e.preventDefault();
        closeBurger();
        var el = document.querySelector(href);
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && burgerOverlay && burgerOverlay.classList.contains('is-open')) closeBurger();
  });

  // FAQ accordion
  document.querySelectorAll('.faq-item').forEach(function(item) {
    item.querySelector('.faq-q').addEventListener('click', function() {
      item.classList.toggle('faq-open');
    });
  });

  // Feedback carousel
  (function() {
    var track = document.getElementById('feedback-track');
    var prevBtn = document.getElementById('feedback-prev');
    var nextBtn = document.getElementById('feedback-next');
    if (!track || !prevBtn || !nextBtn) return;

    function getCardWidth() {
      var card = track.querySelector('.feedback-card');
      return card ? card.offsetWidth : 340;
    }

    function updateArrows() {
      prevBtn.disabled = track.scrollLeft <= 1;
      nextBtn.disabled = track.scrollLeft >= track.scrollWidth - track.clientWidth - 1;
    }

    prevBtn.addEventListener('click', function() {
      track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', function() {
      track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
    });

    track.addEventListener('scroll', updateArrows);
    updateArrows();

    // Drag to scroll
    var dragging = false, startX = 0, startScroll = 0;
    track.addEventListener('pointerdown', function(e) {
      dragging = true;
      startX = e.clientX;
      startScroll = track.scrollLeft;
      track.setPointerCapture(e.pointerId);
      track.style.scrollSnapType = 'none';
    });
    track.addEventListener('pointermove', function(e) {
      if (!dragging) return;
      track.scrollLeft = startScroll - (e.clientX - startX);
    });
    function endDrag(e) {
      if (!dragging) return;
      dragging = false;
      track.style.scrollSnapType = 'x mandatory';
      var cardW = getCardWidth();
      var target = Math.round(track.scrollLeft / cardW) * cardW;
      track.scrollTo({ left: target, behavior: 'smooth' });
      updateArrows();
    }
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);
  })();

  // Format modal
  (function() {
    var fModal = document.querySelector('[data-format-modal]');
    var fDialog = fModal && fModal.querySelector('.format-modal__dialog');
    var fOpenBtn = document.querySelector('[data-format-open]');
    var fCloseEls = fModal && fModal.querySelectorAll('[data-format-close]');
    var fLastFocused = null;
    function openFModal() {
      fLastFocused = document.activeElement;
      if (fModal) fModal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      if (fDialog) fDialog.focus();
      document.addEventListener('keydown', onFKeydown);
    }
    function closeFModal() {
      if (fModal) fModal.setAttribute('hidden', '');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onFKeydown);
      if (fLastFocused instanceof HTMLElement) fLastFocused.focus();
    }
    function onFKeydown(e) { if (e.key === 'Escape') closeFModal(); }
    if (fOpenBtn) fOpenBtn.addEventListener('click', openFModal);
    if (fCloseEls) fCloseEls.forEach(function(el) { el.addEventListener('click', closeFModal); });
    var FLOAD = {
      webinar: { hours: '2-3 часа', note: 'в неделю, до 4-6 часов в недели с двумя встречами' },
      full: { hours: '4-8 часов', note: 'в неделю, с практикой на своём проекте' }
    };
    var fToggleBtns = fModal && fModal.querySelectorAll('[data-load]');
    var fHoursEl = fModal && fModal.querySelector('[data-load-hours]');
    var fNoteEl = fModal && fModal.querySelector('[data-load-note]');
    if (fToggleBtns) fToggleBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        fToggleBtns.forEach(function(b) { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('is-active');
        btn.setAttribute('aria-selected', 'true');
        var mode = btn.getAttribute('data-load');
        if (fHoursEl) fHoursEl.textContent = FLOAD[mode].hours;
        if (fNoteEl) fNoteEl.textContent = FLOAD[mode].note;
      });
    });
  })();

  // Terminal nav
  (function() {
    var termWrap  = document.getElementById('terminal-status');
    var termBtn   = document.querySelector('.js-terminal-toggle');
    var termNav   = document.getElementById('terminal-nav');
    var termItems = termNav ? Array.prototype.slice.call(termNav.querySelectorAll('.terminal-nav__item')) : [];
    var cursorIdx = -1;

    function setCursor(idx) {
      termItems.forEach(function(item) { item.classList.remove('is-focused'); });
      cursorIdx = idx;
      if (idx >= 0 && idx < termItems.length) termItems[idx].classList.add('is-focused');
    }

    function openTermNav() {
      if (!termNav) return;
      termNav.removeAttribute('hidden');
      if (termBtn)  termBtn.setAttribute('aria-expanded', 'true');
      if (termWrap) termWrap.classList.add('is-open');
      termItems.forEach(function(item, i) {
        item.classList.remove('visible', 'is-focused');
        setTimeout(function() { item.classList.add('visible'); }, i * 45);
      });
      setTimeout(function() { setCursor(0); }, 50);
    }
    function closeTermNav() {
      if (!termNav) return;
      termNav.setAttribute('hidden', '');
      if (termBtn)  termBtn.setAttribute('aria-expanded', 'false');
      if (termWrap) termWrap.classList.remove('is-open');
      termItems.forEach(function(item) { item.classList.remove('visible', 'is-focused'); });
      cursorIdx = -1;
    }
    function toggleTermNav() {
      if (termNav && !termNav.hasAttribute('hidden')) closeTermNav();
      else openTermNav();
    }

    if (termBtn) {
      termBtn.addEventListener('click', function(e) { e.stopPropagation(); toggleTermNav(); });
    }

    document.addEventListener('keydown', function(e) {
      var navIsOpen = termNav && !termNav.hasAttribute('hidden');

      if (e.key === 'Escape' && navIsOpen) { closeTermNav(); return; }

      if (e.key === 'ArrowDown' && navIsOpen) {
        e.preventDefault();
        setCursor((cursorIdx + 1) % termItems.length);
        return;
      }
      if (e.key === 'ArrowUp' && navIsOpen) {
        e.preventDefault();
        setCursor((cursorIdx - 1 + termItems.length) % termItems.length);
        return;
      }

      if (e.key === 'Enter') {
        if (navIsOpen && cursorIdx >= 0) {
          e.preventDefault();
          termItems[cursorIdx].click();
          return;
        }
        var tag = document.activeElement ? document.activeElement.tagName : '';
        if (['BUTTON','A','INPUT','TEXTAREA','SELECT'].indexOf(tag) !== -1) return;
        toggleTermNav();
      }
    });

    document.addEventListener('click', function() {
      if (termNav && !termNav.hasAttribute('hidden')) closeTermNav();
    });

    document.querySelectorAll('.js-terminal-link').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var href = this.getAttribute('href');
        if (href && href[0] === '#') {
          e.preventDefault();
          closeTermNav();
          var target = document.querySelector(href);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  })();

  // Logo → scroll to top
  var navLogo = document.querySelector('.nav-logo');
  if (navLogo) navLogo.addEventListener('click', function() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Prereq hint popover
  (function() {
    var hintPopover = document.getElementById('prereq-hint');
    document.querySelectorAll('.js-prereq-hint-toggle').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (!hintPopover) return;
        if (hintPopover.hasAttribute('hidden')) hintPopover.removeAttribute('hidden');
        else hintPopover.setAttribute('hidden', '');
      });
    });
    document.addEventListener('click', function() {
      if (hintPopover && !hintPopover.hasAttribute('hidden')) {
        hintPopover.setAttribute('hidden', '');
      }
    });
  })();
</script>

