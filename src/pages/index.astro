    .pricing-shared-items { flex-direction: column; }
    .pricing-shared-item { border-right: none; padding: 6px 0; }
  }
    @media (max-width: 900px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .pricing-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .pricing-card:last-child { border-bottom: none; }
    .pricing-price { font-size: 22px; }
    .pricing-card { padding: 28px 20px; }
    .referral-block { padding: 28px 20px; }
    .referral-col { padding: 16px 14px; }
    .referral-col-value { font-size: 26px; }
    .nav-cta { padding: 0 16px; font-size: 10px; }
    .nav-logo { display: none; }
    .nav-announce-line2 { display: none; }
    .nav-announce-line1 { font-size: 8px; }
    .nav-dot { width: 5px; height: 5px; }
    nav { display: flex; flex-direction: row; flex-wrap: nowrap; align-items: center; }
    .nav-left { order: 1; flex: 0 0 auto; }
    .nav-center { order: 2; flex: 1 1 0; min-width: 0; overflow: hidden; justify-content: center; }
    .nav-cta { order: 3; flex: 0 0 auto; justify-self: auto; }
  }

  /* SECTION SUB-TITLE (h3 внутри секций) */
  .section-sub-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(20px, 2.2vw, 30px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-top: 48px;
    margin-bottom: 20px;
    color: var(--ink);
  }

  /* TERMINAL STATUS LINE */
  .terminal-status {
    margin-bottom: 32px;
    border-top: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
  }
  .terminal-status__bar {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    background: none;
    border: none;
    padding: 9px 0;
    cursor: pointer;
    text-align: left;
    transition: opacity 0.15s;
  }
  .terminal-status__bar:hover { opacity: 0.75; }
  .terminal-status__overflow {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }
  .terminal-status__track {
    display: inline-flex;
    white-space: nowrap;
  }
  .terminal-status__text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink40);
    padding-right: 64px;
    display: inline-block;
  }
  .terminal-status__text:last-child { display: none; }
  .terminal-status__prompt { color: var(--accent); }
  .terminal-status__cursor {
    color: var(--accent);
    animation: termBlink 1s step-end infinite;
    margin-left: 2px;
  }
  .terminal-status.is-open .terminal-status__cursor { animation: none; opacity: 1; }
  .terminal-status__hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink20);
    flex-shrink: 0;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .terminal-status__bar:hover .terminal-status__hint { color: var(--ink40); }
  .terminal-status.is-open .terminal-status__hint { color: var(--accent); }
  @keyframes termBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* TERMINAL NAV */
  .terminal-nav {
    border-top: 1px solid var(--ink10);
    padding: 6px 0 12px 18px;
  }
  .terminal-nav[hidden] { display: none; }
  .terminal-nav__item {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 7px 0;
    text-decoration: none;
    color: var(--ink60);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.15s;
    position: relative;
  }
  .terminal-nav__item.visible { opacity: 1; transform: translateY(0); }
  .terminal-nav__item:hover { color: var(--ink); }
  .terminal-nav__item.is-focused { color: var(--ink); }
  .terminal-nav__item.is-focused::before {
    content: '>';
    position: absolute;
    left: -16px;
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    top: 50%;
    transform: translateY(-50%);
    line-height: 1;
  }
  .terminal-nav__cmd {
    color: var(--accent);
    min-width: 110px;
    flex-shrink: 0;
    font-size: 11px;
  }
  .terminal-nav__item--cta .terminal-nav__label { color: var(--accent); }
  .terminal-nav__item--cta:hover .terminal-nav__label { color: var(--ink); }

  @media (max-width: 640px) {
    .terminal-status__text:last-child { display: inline-block; }
    .terminal-status.is-open .terminal-status__track { animation-play-state: paused; }
    .terminal-status__track { animation: termScroll 14s linear infinite; }
    @keyframes termScroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  }

  /* PREREQ HINT POPOVER */
  .prereq-hint-wrap {
    position: relative;
    display: inline-block;
    margin-top: 16px;
  }
  .prereq-hint-popover {
    position: absolute;
    top: 50%;
    left: calc(100% + 12px);
    transform: translateY(-50%);
    z-index: 50;
    width: min(380px, calc(100vw - 48px));
    background: var(--bg);
    border: 1px solid var(--ink20);
    border-left: 3px solid var(--accent);
    padding: 14px 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .prereq-hint-popover[hidden] { display: none; }
  @media (max-width: 640px) {
    .prereq-hint-popover {
      top: calc(100% + 6px);
      left: 0;
      transform: none;
    }
  }

  /* ROLE CARDS — для кого */
  .roles-block {
    margin: 40px 0 0px;
  }
  .roles-primary {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--ink10);
    margin-bottom: 12px;
  }
  .role-card {
    padding: 24px 28px;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .role-card:last-child { border-right: none; }
  .role-card__num {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
  }
  .role-card__title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .roles-primary { grid-template-columns: 1fr; }
    .role-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .role-card:last-child { border-bottom: none; }
  }

  /* HERO ACTIONS */
  .hero-actions {
    display: flex;
    align-items: stretch;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-invite {
    display: flex;
    align-items: center;
    font-family: 'JetBrains Mono', monospace !important;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.8rem;
    background: var(--ink);
    color: var(--bg);
    border: 1px solid var(--ink);
    border-radius: 0 !important;
    padding: 16px 24px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.12s, color 0.12s;
  }
  .btn-invite:hover { background: var(--accent); color: var(--ink); }

  /* VIDEO MODAL */
  .video-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    background: rgba(10,10,15,0.85);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .video-modal.is-open { opacity: 1; visibility: visible; pointer-events: auto; }
  .video-modal__box {
    position: relative;
    width: 100%;
    max-width: 620px;
    background: var(--ink);
    padding: 44px 32px 32px;
    overflow-y: auto;
    max-height: 92vh;
  }
  .video-modal__close {
    position: absolute;
    top: 12px; right: 12px;
    background: transparent;
    border: 1px solid rgba(245,245,240,0.2);
    color: rgba(245,245,240,0.5);
    width: 32px; height: 32px;
    cursor: pointer;
    font-size: 18px;
    line-height: 32px;
    text-align: center;
    transition: color 0.2s, border-color 0.2s;
  }
  .video-modal__close:hover { color: var(--bg); border-color: rgba(245,245,240,0.6); }
  .video-modal__videos { display: flex; flex-direction: column; gap: 28px; }
  .video-modal__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .video-modal__ratio {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #000;
  }
  .video-modal__ratio iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
  }
  @media (max-width: 640px) {
    .hero-actions { flex-direction: column; align-items: stretch; }
    .btn-invite { justify-content: center; padding: 12px 20px; font-size: 11px; letter-spacing: 0.06em; }
    .video-modal__box { padding: 44px 16px 24px; }
  }

  /* WHY-NOW TABS (about) */
  .tabs-card { width: 100%; max-width: none; margin-top: 40px; }
  .tabs-nav {
    display: flex;
    gap: 4px;
    align-items: flex-end;
  }
  .tab-btn {
    flex: 1 1 0;
    min-width: 0;
    text-align: left;
    background: transparent;
    border: 1px solid var(--ink10);
    border-bottom: none;
    padding: 14px 16px 16px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: var(--ink40);
    font-family: inherit;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tab-btn:hover:not(.is-active) { background: var(--ink05); color: var(--ink60); }
  .tab-num {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 22px;
    line-height: 1;
    color: var(--ink20);
  }
  .tab-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.4;
    word-break: break-word;
  }
  .tab-btn.is-active {
    background: var(--ink05);
    color: var(--ink);
    margin-bottom: -1px;              /* перекрываем верхнюю границу тела */
    position: relative;
    z-index: 2;
  }
  .tab-btn.is-active .tab-num { color: var(--accent); }

  .tabs-body {
    background: var(--ink05);
    border: 1px solid var(--ink10);
    padding: 40px 44px;
    display: grid;                     /* все панели в одной ячейке → высота = самой высокой */
  }

  /* Все панели наложены друг на друга: высота тела фиксируется по самой высокой,
     низ не «прыгает» при переключении. Неактивные скрыты, но занимают место. */
  .tab-panel { grid-area: 1 / 1; visibility: hidden; }
  .tab-panel.is-active { visibility: visible; }

  .panel-title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(24px, 3vw, 34px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 32px;
  }

  .panel-lead {
    font-size: 14px;
    line-height: 1.8;
    color: var(--ink60);
  }
  .panel-lead + .panel-lead { margin-top: 18px; }

  .author-list {
    list-style: none;
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .author-list + .panel-lead { margin-top: 18px; }
  .author-item {
    position: relative;
    padding-left: 26px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink60);
  }
  .author-item::before {
    content: '→';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 600;
  }

  .panel-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 32px;
    padding: 13px 26px;
    background: var(--ink);
    color: var(--bg);
    border: 1px solid var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .panel-btn:hover { background: var(--accent); color: var(--ink); border-color: var(--accent); }

  .panel-item { margin-bottom: 24px; }
  .panel-item:last-child { margin-bottom: 0; }
  .item-h {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 14px;
    color: var(--ink);
    margin-bottom: 6px;
    line-height: 1.4;
  }
  .item-text {
    font-size: 14px;
    line-height: 1.8;
    color: var(--ink60);
  }
  a.item-cited {
    display: block;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  a.item-cited:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .cite-arrow { color: var(--accent); white-space: nowrap; font-weight: 600; }

  @media (max-width: 640px) {
    .tabs-body { padding: 28px 20px; }
    .tab-btn { align-items: center; padding: 12px 8px; }
    .tab-label { display: none; }        /* на мобилке — только номера */
  }

  /* ===== PRICING / FORMATS (тёмная инверсия, #register) ===== */
  .pricing-section {
    /* фон — во всю ширину страницы (как и остальные <section>), содержимое — внутри .pricing-inner */
    padding: 80px 24px;
    background: var(--ink);
    color: var(--bg);
    font-variant-numeric: tabular-nums;
  }
  .pricing-inner { max-width: 1200px; margin: 0 auto; }
  .pricing-section .section-title { color: var(--bg); margin-bottom: 24px; }
  .pricing-section .bracket-label { margin-bottom: 12px; }

  /* вводный блок секции — заголовок и подводка по центру */
  .pricing-head { text-align: center; }

  .pricing-lead {
    max-width: 680px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--cream-muted);
    margin: 0 auto 48px;
  }

  .pricing-main { max-width: 70%; margin: 0 auto 32px; border: 1px solid var(--cream-border); }
  .pricing-main__head { padding: 40px 40px 32px; border-bottom: 1px solid var(--cream-border); }
  .pricing-main__head-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 16px; }
  .pricing-main__head-row .pricing-main__title { margin: 0; }
  .pricing-main__title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--bg);
    margin: 0 0 16px;
  }
  .pricing-main__desc { font-size: 14px; line-height: 1.7; color: var(--cream-muted); max-width: 560px; margin: 0; }
  .pricing-main__desc + .pricing-main__desc { margin-top: 12px; }

  .pricing-value-list { list-style: none; margin: 0; padding: 0; }
  .pricing-value-list li {
    position: relative;
    padding: 20px 40px 20px 64px;
    border-bottom: 1px solid var(--cream-border);
    font-size: 14px;
    line-height: 1.6;
    color: var(--bg);
  }
  .pricing-value-list li::before {
    content: '→';
    position: absolute;
    left: 40px;
    top: 20px;
    color: var(--accent);
    font-weight: 600;
  }
  .pricing-value-list li:last-child { border-bottom: none; }
  .pricing-value-list li.is-placeholder { color: var(--accent); }

  /* вложенный список материалов курса — табуляция диагональной стрелкой ↗ */
  .pricing-sublist { list-style: none; margin: 10px 0 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .pricing-sublist li {
    position: relative;
    padding: 0 0 0 22px;
    border-bottom: none;
    font-size: 13px;
    line-height: 1.5;
    color: var(--cream-muted);
  }
  .pricing-sublist li::before {
    content: '↗';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
  }
  .pricing-value-list li.is-price { padding-bottom: 40px; }      /* тот же вес, что раньше давал .pricing-main__cta */
  .pricing-value-list li.is-price::before { content: none; }  /* цена — без маркера-стрелки */
  .pricing-value-list .price-num {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 24px;
    letter-spacing: -0.01em;
    color: var(--accent);
  }
  .pricing-value-list .price-unit { font-size: 13px; color: var(--cream-muted); }

  .pricing-price-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 20px; }
  .pricing-value-list li.is-price .cta-btn { font-size: 14.4px; } /* 12px + 20%, только для этой кнопки */

  /* трёхколоночная полоса под ценой и СТА — тот же стиль, что у .pricing-footer */
  .pricing-price-footer {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--cream-border);
    flex-wrap: wrap;
    margin-left: -64px;   /* bleed до края .pricing-main — гасим левый паддинг .is-price (64px, под стрелку) */
    margin-right: -40px;  /* гасим правый паддинг .is-price (40px) */
    margin-bottom: -40px; /* гасим нижний паддинг .is-price (40px) */
  }
  .pricing-price-footer-item {
    padding: 14px 20px;
    font-size: 12px;
    line-height: 1.5;
    color: var(--cream-muted);
    border-right: 1px solid var(--cream-border);
    flex: 1;
    min-width: 200px;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .pricing-price-footer-item:last-child { border-right: none; }
  .pricing-price-footer-item:hover { background: var(--bg); color: var(--ink); }

  /* вторичная кнопка на тёмном фоне: контурная */
  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--bg);
    border: 1px solid var(--cream-border);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 32px;
    cursor: pointer;
    transition: border-color 0.3s ease, color 0.3s ease;
    white-space: nowrap;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  /* та же анимация, что у .format-floor__btn — быстрая прямая заливка вместо смены цвета рамки */
  .btn-secondary--swap { transition: background 0.12s, color 0.12s, border-color 0.12s; }
  .btn-secondary--swap:hover { background: var(--accent); color: var(--ink); border-color: var(--accent); }

  .pricing-active {
    max-width: 70%;
    margin: 0 auto 24px;
    background: var(--cream-panel);
    border: 1px solid var(--cream-border);
    padding: 32px 40px;
  }
  .pricing-active__head { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .pricing-active__badge {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: transparent;
    border: 1px solid var(--accent);
    padding: 6px 12px;
    white-space: nowrap;
  }
  .pricing-active__title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 24px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--bg);
    margin: 0 0 20px;
  }
  .pricing-active__cta { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .pricing-active__note { font-size: 14px; line-height: 1.6; font-weight: 700; color: var(--accent); }

  .pricing-active__list { list-style: none; margin: 0 0 24px; padding: 0; }
  .pricing-active__list li {
    font-size: 14px;
    line-height: 1.6;
    color: var(--white);
    border-left: 2px solid var(--accent);
    padding-left: 14px;
    margin-bottom: 14px;
  }
  .pricing-active__list li:last-child { margin-bottom: 0; }

  .pricing-group {
    max-width: 70%;
    background: var(--cream-panel);
    border: 1px solid var(--cream-border);
    margin: 0 auto 24px;
    padding: 32px 40px;
  }
