  // Feedback carousel — infinite loop (clones + teleport on native scroll)
  (function() {
    var track = document.getElementById('feedback-track');
    var prevBtn = document.getElementById('feedback-prev');
    var nextBtn = document.getElementById('feedback-next');
    if (!track) return;

    var originals = Array.prototype.slice.call(track.querySelectorAll('.feedback-card'));
    if (originals.length === 0) return;

    function getCardWidth() {
      return originals[0] ? originals[0].offsetWidth : 340;
    }
    function measureSet() {
      var w = 0;
      originals.forEach(function(card) { w += card.offsetWidth; });
      return w;
    }
    var setWidth = measureSet();

    // Clone a full set before and after the originals so the seam is never visible.
    function appendCloneSet(where) {
      var frag = document.createDocumentFragment();
      originals.forEach(function(card) {
        var clone = card.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        clone.classList.add('feedback-card--clone');
        frag.appendChild(clone);
      });
      if (where === 'before') track.insertBefore(frag, track.firstChild);
      else track.appendChild(frag);
    }
    appendCloneSet('after');
    appendCloneSet('before');

    function jumpTo(x) {
      var prev = track.style.scrollBehavior;
      track.style.scrollBehavior = 'auto';
      track.scrollLeft = x;
      track.style.scrollBehavior = prev;
    }
    jumpTo(setWidth); // start on the first real card (after the before-clones)

    var dragging = false, startX = 0, startScroll = 0, wrapping = false, isTouch = false;

    // Teleport by one set width when the user drifts into a clone zone — same
    // card at the same offset, so the jump is invisible.
    function wrap() {
      if (wrapping) return;
      var sl = track.scrollLeft;
      if (sl < setWidth) {
        wrapping = true;
        jumpTo(sl + setWidth);
        if (dragging) startScroll += setWidth;
        wrapping = false;
      } else if (sl >= setWidth * 2) {
        wrapping = true;
        jumpTo(sl - setWidth);
        if (dragging) startScroll -= setWidth;
        wrapping = false;
      }
    }

    prevBtn && prevBtn.addEventListener('click', function() {
      track.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
    });
    nextBtn && nextBtn.addEventListener('click', function() {
      track.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
    });

    track.addEventListener('scroll', wrap);

    // Drag to scroll
    track.addEventListener('pointerdown', function(e) {
      dragging = true;
      isTouch = e.pointerType === 'touch';
      startX = e.clientX;
      startScroll = track.scrollLeft;
      track.setPointerCapture(e.pointerId);
      track.style.scrollSnapType = 'none';
    });
    track.addEventListener('pointermove', function(e) {
      if (!dragging) return;
      var delta = e.clientX - startX;
      // On touch, cap one gesture to a single card so native-momentum overlap
      // can't carry the track across the clone seam mid-flight.
      if (isTouch) {
        var cap = getCardWidth();
        if (delta > cap) delta = cap;
        else if (delta < -cap) delta = -cap;
      }
      track.scrollLeft = startScroll - delta;
    });
    function endDrag(e) {
      if (!dragging) return;
      dragging = false;
      track.style.scrollSnapType = 'x mandatory';
      var cardW = getCardWidth();
      var target = Math.round(track.scrollLeft / cardW) * cardW;
      track.scrollTo({ left: target, behavior: 'smooth' });
    }
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);

    // Card widths change between breakpoints — re-measure so the loop math holds.
    window.addEventListener('resize', function() {
      setWidth = measureSet();
    });
  })();

