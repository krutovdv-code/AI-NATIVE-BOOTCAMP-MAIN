    function openFModal() {
      fLastFocused = document.activeElement;
      if (fModal) fModal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      if (fDialog) fDialog.focus();
      document.addEventListener('keydown', onFKeydown);
    }
    function closeFModal() {
      if (fModal) fModal.setAttribute('hidden', '');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onFKeydown);
      if (fLastFocused instanceof HTMLElement) fLastFocused.focus();
    }
    function onFKeydown(e) { if (e.key === 'Escape') closeFModal(); }
    if (fOpenBtn) fOpenBtn.addEventListener('click', openFModal);
    if (fCloseEls) fCloseEls.forEach(function(el) { el.addEventListener('click', closeFModal); });
    var FLOAD = {
      webinar: { hours: '2-3 часа', note: 'в неделю, до 4-6 часов в недели с двумя встречами' },
      full: { hours: '4-8 часов', note: 'в неделю, с практикой на своём проекте' }
    };
    var fToggleBtns = fModal && fModal.querySelectorAll('[data-load]');
    var fHoursEl = fModal && fModal.querySelector('[data-load-hours]');
    var fNoteEl = fModal && fModal.querySelector('[data-load-note]');
    if (fToggleBtns) fToggleBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        fToggleBtns.forEach(function(b) { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('is-active');
        btn.setAttribute('aria-selected', 'true');
        var mode = btn.getAttribute('data-load');
        if (fHoursEl) fHoursEl.textContent = FLOAD[mode].hours;
        if (fNoteEl) fNoteEl.textContent = FLOAD[mode].note;
      });
    });
  })();

  // Lesson format modal
  (function() {
    var lModal = document.querySelector('[data-lesson-modal]');
    var lDialog = lModal && lModal.querySelector('.format-modal__dialog');
    var lOpenBtns = document.querySelectorAll('[data-lesson-open]');
    var lCloseEls = lModal && lModal.querySelectorAll('[data-lesson-close]');
    var lLastFocused = null;
    function openLModal() {
      lLastFocused = document.activeElement;
      if (lModal) lModal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      if (lDialog) lDialog.focus();
      document.addEventListener('keydown', onLKeydown);
    }
    function closeLModal() {
      if (lModal) lModal.setAttribute('hidden', '');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onLKeydown);
      if (lLastFocused instanceof HTMLElement) lLastFocused.focus();
    }
    function onLKeydown(e) { if (e.key === 'Escape') closeLModal(); }
    lOpenBtns.forEach(function(btn) { btn.addEventListener('click', openLModal); });
    if (lCloseEls) lCloseEls.forEach(function(el) { el.addEventListener('click', closeLModal); });
  })();

  // Terminal nav
  (function() {
    var termWrap  = document.getElementById('terminal-status');
    var termBtn   = document.querySelector('.js-terminal-toggle');
    var termNav   = document.getElementById('terminal-nav');
    var termItems = termNav ? Array.prototype.slice.call(termNav.querySelectorAll('.terminal-nav__item')) : [];
    var cursorIdx = -1;

    function setCursor(idx) {
      termItems.forEach(function(item) { item.classList.remove('is-focused'); });
      cursorIdx = idx;
      if (idx >= 0 && idx < termItems.length) termItems[idx].classList.add('is-focused');
    }

    function openTermNav() {
      if (!termNav) return;
      termNav.removeAttribute('hidden');
      if (termBtn)  termBtn.setAttribute('aria-expanded', 'true');
      if (termWrap) termWrap.classList.add('is-open');
      termItems.forEach(function(item, i) {
        item.classList.remove('visible', 'is-focused');
        setTimeout(function() { item.classList.add('visible'); }, i * 45);
      });
      setTimeout(function() { setCursor(0); }, 50);
    }
    function closeTermNav() {
      if (!termNav) return;
      termNav.setAttribute('hidden', '');
      if (termBtn)  termBtn.setAttribute('aria-expanded', 'false');
      if (termWrap) termWrap.classList.remove('is-open');
      termItems.forEach(function(item) { item.classList.remove('visible', 'is-focused'); });
      cursorIdx = -1;
    }
    function toggleTermNav() {
      if (termNav && !termNav.hasAttribute('hidden')) closeTermNav();
      else openTermNav();
    }

    if (termBtn) {
      termBtn.addEventListener('click', function(e) { e.stopPropagation(); toggleTermNav(); });
    }

    document.addEventListener('keydown', function(e) {
      var navIsOpen = termNav && !termNav.hasAttribute('hidden');

      if (e.key === 'Escape' && navIsOpen) { closeTermNav(); return; }

      if (e.key === 'ArrowDown' && navIsOpen) {
        e.preventDefault();
        setCursor((cursorIdx + 1) % termItems.length);
        return;
      }
      if (e.key === 'ArrowUp' && navIsOpen) {
        e.preventDefault();
        setCursor((cursorIdx - 1 + termItems.length) % termItems.length);
        return;
      }

      if (e.key === 'Enter') {
        if (navIsOpen && cursorIdx >= 0) {
          e.preventDefault();
          termItems[cursorIdx].click();
          return;
        }
        var tag = document.activeElement ? document.activeElement.tagName : '';
        if (['BUTTON','A','INPUT','TEXTAREA','SELECT'].indexOf(tag) !== -1) return;
        toggleTermNav();
      }
    });

    document.addEventListener('click', function() {
      if (termNav && !termNav.hasAttribute('hidden')) closeTermNav();
    });

    document.querySelectorAll('.js-terminal-link').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var href = this.getAttribute('href');
        if (href && href[0] === '#') {
          e.preventDefault();
          closeTermNav();
          var target = document.querySelector(href);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  })();

  // Logo → scroll to top
  var navLogo = document.querySelector('.nav-logo');
  if (navLogo) navLogo.addEventListener('click', function() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Prereq hint popover
  (function() {
    var hintPopover = document.getElementById('prereq-hint');
    document.querySelectorAll('.js-prereq-hint-toggle').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (!hintPopover) return;
        if (hintPopover.hasAttribute('hidden')) hintPopover.removeAttribute('hidden');
        else hintPopover.setAttribute('hidden', '');
      });
    });
    document.addEventListener('click', function() {
      if (hintPopover && !hintPopover.hasAttribute('hidden')) {
        hintPopover.setAttribute('hidden', '');
      }
    });
  })();

  // Видео-модалка с визитками авторов
  (function() {
    var vModal = document.getElementById('video-invite-modal');
    function openVideoModal() {
      if (!vModal) return;
      vModal.querySelectorAll('iframe[data-src]').forEach(function(iframe) {
        if (!iframe.getAttribute('src')) {
          iframe.setAttribute('src', iframe.getAttribute('data-src'));
        }
      });
      vModal.classList.add('is-open');
      vModal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeVideoModal() {
      if (!vModal) return;
      vModal.classList.remove('is-open');
      vModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      vModal.querySelectorAll('iframe').forEach(function(iframe) {
        iframe.removeAttribute('src');
      });
    }
    document.querySelectorAll('.js-open-video-modal').forEach(function(btn) {
      btn.addEventListener('click', openVideoModal);
    });
    document.querySelectorAll('.js-close-video-modal').forEach(function(btn) {
      btn.addEventListener('click', closeVideoModal);
    });
    if (vModal) {
      vModal.addEventListener('click', function(e) {
        if (e.target === vModal) closeVideoModal();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && vModal.classList.contains('is-open')) closeVideoModal();
      });
    }
  })();
</script>

</body>
</html>
