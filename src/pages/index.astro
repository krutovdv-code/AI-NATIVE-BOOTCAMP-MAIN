  /* TERMINAL STATUS LINE */
  .terminal-status {
    margin-bottom: 32px;
    border-top: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
  }
  .terminal-status__bar {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    background: none;
    border: none;
    padding: 9px 0;
    cursor: pointer;
    text-align: left;
    transition: opacity 0.15s;
  }
  .terminal-status__bar:hover { opacity: 0.75; }
  .terminal-status__overflow {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }
  .terminal-status__track {
    display: inline-flex;
    white-space: nowrap;
  }
  .terminal-status__text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink40);
    padding-right: 64px;
    display: inline-block;
  }
  .terminal-status__text:last-child { display: none; }
  .terminal-status__prompt { color: var(--accent); }
  .terminal-status__cursor {
    color: var(--accent);
    animation: termBlink 1s step-end infinite;
    margin-left: 2px;
  }
  .terminal-status.is-open .terminal-status__cursor { animation: none; opacity: 1; }
  .terminal-status__hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink20);
    flex-shrink: 0;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .terminal-status__bar:hover .terminal-status__hint { color: var(--ink40); }
  .terminal-status.is-open .terminal-status__hint { color: var(--accent); }
  @keyframes termBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* TERMINAL NAV */
  .terminal-nav {
    border-top: 1px solid var(--ink10);
    padding: 6px 0 12px 18px;
  }
  .terminal-nav[hidden] { display: none; }
  .terminal-nav__item {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 7px 0;
    text-decoration: none;
    color: var(--ink60);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.15s;
    position: relative;
  }
  .terminal-nav__item.visible { opacity: 1; transform: translateY(0); }
  .terminal-nav__item:hover { color: var(--ink); }
  .terminal-nav__item.is-focused { color: var(--ink); }
  .terminal-nav__item.is-focused::before {
    content: '>';
    position: absolute;
    left: -16px;
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    top: 50%;
    transform: translateY(-50%);
    line-height: 1;
