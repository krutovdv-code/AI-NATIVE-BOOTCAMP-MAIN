<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; border-radius: 0 !important; }
  
  :root {
    --bg: #f5f5f0;
    --ink: #0a0a0f;
    --accent: #f5a623;
    --ink10: rgba(10,10,15,0.10);
    --ink20: rgba(10,10,15,0.20);
    --ink40: rgba(10,10,15,0.40);
    --ink60: rgba(10,10,15,0.60);
    --ink05: rgba(10,10,15,0.05);
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
    font-variant-numeric: tabular-nums;
    text-rendering: optimizeLegibility;
    max-width: 1440px;
    margin: 0 auto;
    overflow-x: hidden;
  }

  h1, h2, h3, .display {
    font-family: 'Roboto Condensed', 'Arial Narrow', Arial, sans-serif !important;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    text-rendering: optimizeLegibility;
    font-variant-numeric: tabular-nums;
  }

  /* NAV — приклеена к верху при скролле (особенно на мобилке) */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 48px;
    background: rgba(245,245,240,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--ink10);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 24px;
    max-width: 1440px;
    margin: 0 auto;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  .nav-logo {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: color 0.15s;
  }
  .nav-logo:hover { color: var(--accent); }
  .nav-center {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 11px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50% !important;
    background: var(--accent);
    flex-shrink: 0;
    animation: navPulse 1.5s ease-in-out infinite;
  }
  @keyframes navPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245,166,35,0.6); }
    50%       { box-shadow: 0 0 0 5px rgba(245,166,35,0); }
  }
  .nav-announce {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .nav-announce-line1 {
    font-size: 10.5px;
    font-weight: 600;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
  }
  .nav-announce-line2 {
    font-size: 9px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
    white-space: nowrap;
  }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    align-self: stretch;
    justify-self: end;
    position: relative;
    overflow: hidden;
    padding: 0 28px;
    background: var(--accent);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    cursor: pointer;
    border: none;
    line-height: 1;
  }
  .nav-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }
  .nav-cta:hover::before { transform: translateX(0); }
  .nav-cta span { position: relative; z-index: 1; }
  .nav-cta:hover span { color: #f5f5f0; }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--ink60);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .pulse-dot {
    width: 7px; height: 7px;
    background: var(--accent);
    border-radius: 50% !important;
    animation: pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  /* Левая часть навигации: лого + бургер */
  .nav-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  /* Бургер-меню — без окантовки и квадратика */
  .nav-burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    background: none;
    border: none;
    outline: none;
    box-shadow: none;
    cursor: pointer;
    position: relative;
    z-index: 101;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-burger:hover { background: transparent; }
  .nav-burger:focus { outline: none; box-shadow: none; }
  .nav-burger:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.is-open span:nth-child(2) { opacity: 0; }
  .nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .burger-overlay {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: rgba(10, 10, 15, 0.9);
    backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .burger-overlay.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .burger-panel {
    position: fixed;
    top: 48px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    padding: 24px 20px 32px;
    overflow: auto;
    display: flex;
    flex-direction: column;
    -webkit-overflow-scrolling: touch;
  }
  .burger-panel a,
  .burger-panel .burger-cta {
    display: block;
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--bg);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid rgba(245,245,240,0.15);
    transition: color 0.2s ease;
  }
  .burger-panel a:hover { color: var(--accent); }
  .burger-panel .burger-cta {
    margin-top: auto;
    padding-top: 24px;
    border-bottom: none;
    text-align: center;
    background: var(--accent);
    color: var(--ink);
    border-radius: 0;
    cursor: pointer;
    width: 100%;
    margin-left: 0;
    margin-right: 0;
  }
  .burger-panel .burger-cta:hover { opacity: 0.95; color: var(--ink); }

  /* SECTIONS */
  section { 
    padding: 80px 24px; 
    border-bottom: 1px solid var(--ink10);
    position: relative;
  }
  .section-grid {
    display: block;
    max-width: 1200px;
  }

  /* HERO — контент отступает от фиксированного навбара, без обрезки сверху */
  #hero {
    padding: 88px 24px 80px;
    padding-top: max(88px, 56px + 48px);
    border-bottom: 1px solid var(--ink10);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .hero-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 24px;
  }
  .hero-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(56px, 8vw, 120px);
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    max-width: 1100px;
    margin-bottom: 40px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero-title .word { display: inline-block; opacity: 1; }
  .js .hero-title .word { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .js .hero-title .word.visible { opacity: 1; transform: translateY(0); }
  .hero-accent { color: var(--accent); }
  .hero-sub {
    border-left: 2px solid var(--accent);
    padding-left: 24px;
    max-width: 640px;
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink60);
    margin-bottom: 56px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 480px;
    border: 1px solid var(--ink10);
  }
  .stat-box {
    padding: 24px 28px;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
    /* сюда добавить: */
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .stat-box:last-child { border-right: none; }
  .stat-num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 48px;
    line-height: 1;
    color: var(--accent);
    display: block;
    margin-bottom: 6px;
  }
  .stat-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink40);
  }

  /* CTA BUTTON */
  .cta-btn {
    display: inline-block;
    width: auto;
    max-width: max-content;
    position: relative;
    overflow: hidden;
    clip-path: inset(0);
    padding: 16px 40px;
    background: var(--accent);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    cursor: pointer;
    border: none;
  }
  .cta-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }
  .cta-btn:hover::before { transform: translateX(0); }
  .cta-btn span { position: relative; z-index: 1; }
  .cta-btn:hover span { color: #f5f5f0; }

  /* ABOUT / LEGEND */
  .about-text {
    font-size: 15px;
    line-height: 1.8;
    color: var(--ink60);
    max-width: 720px;
    margin-bottom: 32px;
  }
  .about-text strong { color: var(--ink); font-weight: 600; }
  .bracket-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
    display: block;
  }

  /* FOR WHOM */
  .audience-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .audience-item {
    padding: 24px 28px;
    border-right: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .audience-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .audience-item.visible { opacity: 1; transform: translateY(0); }
  .audience-item:nth-child(even) { border-right: none; }
  .audience-item:nth-last-child(-n+2) { border-bottom: none; }
  .audience-num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 32px;
    color: var(--ink20);
    margin-bottom: 8px;
  }
  .audience-text {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }

  /* WHAT YOU LEARN */
  .learn-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .learn-item {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .learn-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .learn-item.visible { opacity: 1; transform: translateY(0); }
  .learn-item:nth-child(even) { border-right: none; }
  .learn-item:nth-last-child(-n+2) { border-bottom: none; }
  .learn-arrow {
    color: var(--accent);
    font-size: 18px;
    margin-bottom: 10px;
    display: block;
  }
  .learn-text {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .learn-text strong { color: var(--ink); }

  /* OUTCOMES BANNER */
  .outcomes-banner {
    background: var(--ink);
    padding: 36px 48px;
    display: flex;
    align-items: center;
    gap: 48px;
    flex-wrap: wrap;
    max-width: 1200px;
  }
  .outcomes-banner-label {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 28px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .outcomes-banner-text {
    font-size: 14px;
    color: #f5f5f0;
    line-height: 1.6;
  }
  @media (max-width: 640px) {
    .outcomes-banner { padding: 28px 24px; gap: 16px; flex-direction: column; align-items: flex-start; }
  }

  /* ABOUT REDESIGN */
  .about-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--ink10);
    margin-bottom: 2px;
  }
  .about-compare-col {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
  }
  .about-compare-col:last-child { border-right: none; }
  .about-compare-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink40);
    margin-bottom: 16px;
    display: block;
  }
  .about-compare-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .about-compare-list li {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
    padding: 8px 0 8px 14px;
    border-bottom: 1px solid var(--ink05);
    position: relative;
  }
  .about-compare-list li:last-child { border-bottom: none; }
  .about-compare-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--ink20);
  }
  .about-compare-col:last-child .about-compare-label { color: var(--accent); }
  .about-compare-col:last-child .about-compare-list li::before {
    content: '→';
    color: var(--accent);
  }
  .about-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--ink10);
    margin-bottom: 2px;
  }
  .about-card {
    padding: 32px 32px;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
  }
  .about-card:last-child { border-right: none; }
  .about-card--dark { background: var(--ink); }
  .about-card-title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.0;
    margin-bottom: 16px;
    color: var(--ink);
  }
  .about-card--dark .about-card-title { color: var(--accent); }
  .about-card-text {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .about-card--dark .about-card-text { color: rgba(245,245,240,0.55); }
  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--ink10);
  }
  .about-stat {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
  }
  .about-stat:last-child { border-right: none; }
  .about-stat-num {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 40px;
    color: var(--accent);
    line-height: 1;
    display: block;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .about-stat-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink40);
    line-height: 1.5;
  }
  @media (max-width: 900px) {
    .about-compare,
    .about-cards { grid-template-columns: 1fr; }
    .about-compare-col { border-right: none; border-bottom: 1px solid var(--ink10); }
    .about-compare-col:last-child { border-bottom: none; }
    .about-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .about-card:last-child { border-bottom: none; }
    .about-stats { grid-template-columns: 1fr 1fr; }
    .about-stat:nth-child(2) { border-right: none; }
    .about-stat:nth-child(1),
    .about-stat:nth-child(2) { border-bottom: 1px solid var(--ink10); }
  }
  @media (max-width: 640px) {
    .about-stats { grid-template-columns: 1fr; }
    .about-stat { border-right: none; border-bottom: 1px solid var(--ink10); }
    .about-stat:last-child { border-bottom: none; }
  }

  /* CONTEXT */
  .context-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid rgba(245,245,240,0.12);
    margin-bottom: 32px;
  }
  .context-card {
    padding: 32px 28px;
    border-right: 1px solid var(--ink10);
  }
  .context-card:last-child { border-right: none; }
  .context-num {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 40px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .context-title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .context-desc {
    font-size: 12px;
    color: var(--ink60);
    line-height: 1.7;
  }
  .context-cta-row {
    display: flex;
    align-items: center;
    gap: 32px;
    padding-top: 28px;
    flex-wrap: wrap;
  }
  .context-cta-text {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink60);
  }
  @media (max-width: 900px) {
    .context-grid { grid-template-columns: 1fr 1fr; }
    .context-card:nth-child(2) { border-right: none; }
    .context-card:nth-child(1),
    .context-card:nth-child(2) { border-bottom: 1px solid var(--ink10); }
  }
  @media (max-width: 640px) {
    .context-grid { grid-template-columns: 1fr; }
    .context-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .context-card:last-child { border-bottom: none; }
    .context-cta-row { flex-direction: column; align-items: flex-start; }
  }

  /* FORMAT MODAL */
  .format-floor {
    background: var(--bg);
    color: var(--ink);
    border: 1px solid var(--ink10);
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .format-floor__text { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; line-height: 1.55; margin: 0; max-width: 80ch; color: var(--ink60); }
