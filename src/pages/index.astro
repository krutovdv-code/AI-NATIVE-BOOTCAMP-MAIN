  /* FEEDBACK CAROUSEL */
  .feedback-carousel-wrap { margin-top: 48px; }
  .feedback-track-outer {
    position: relative;
    overflow: hidden;
  }
  .feedback-track-outer::after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 80px;
    background: linear-gradient(to right, transparent, var(--bg));
    pointer-events: none;
    z-index: 2;
  }
  .feedback-track {
    display: flex;
    align-items: stretch;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    cursor: grab;
    user-select: none;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--ink10);
  }
  .feedback-track:active { cursor: grabbing; }
  .feedback-track::-webkit-scrollbar { display: none; }
  .feedback-card {
    flex-shrink: 0;
    scroll-snap-align: start;
    border-right: 1px solid var(--ink10);
