  B2_STEPS.forEach(function(s) {
    var el = document.createElement("div");
    el.className = "b2-step";
    el.innerHTML = "<div class='b2-step-era " + s.era + "'>" + s.label + "</div><div class='b2-step-title'>" + s.title + "</div><p class='b2-step-text'>" + s.text + "</p>";
    b2ContentEl.appendChild(el);
  });
  var b2DotEls = B2_STEPS.map(function(_, i) {
    var d = document.createElement("div");
    d.className = "b2-snap-dot";
    b2DotsContainer.appendChild(d);
    d.addEventListener("click", (function(idx) { return function() { b2GoTo(idx); }; })(i));
    return d;
  });
  function b2GetPositions() {
    var h = b2Timeline.offsetHeight, pad = 20;
    return B2_STEPS.map(function(_, i) { return pad + (i / (B2_N - 1)) * (h - pad * 2); });
  }
  function b2Layout() {
    b2Timeline.style.height = b2ContentEl.offsetHeight + "px";
    var pos = b2GetPositions();
    b2DotEls.forEach(function(d, i) { d.style.top = pos[i] + "px"; });
    b2LabelBefore.style.top = ((pos[0] + pos[2]) / 2) + "px";
    b2LabelAfter.style.top  = ((pos[3] + pos[5]) / 2) + "px";
    b2Handle.style.transition = "none";
    b2Handle.style.top = pos[b2ActiveStep] + "px";
  }
  function b2Nearest(relY) {
    var pos = b2GetPositions(), best = 0, bestDist = Infinity;
    pos.forEach(function(p, i) { var d = Math.abs(relY - p); if (d < bestDist) { bestDist = d; best = i; } });
    return best;
  }
  var b2ActiveStep = 0;
  function b2GoTo(step, animate) {
    if (animate === undefined) animate = true;
    b2ActiveStep = step;
    b2Handle.style.transition = animate ? "top 0.15s ease" : "none";
    b2Handle.style.top = b2GetPositions()[step] + "px";
    b2DotEls.forEach(function(d, i) { d.classList.toggle("reached", i <= step); });
    b2ContentEl.querySelectorAll(".b2-step").forEach(function(el, i) { el.classList.toggle("visible", i <= step); });
  }
  var b2Dragging = false;
  b2Handle.addEventListener("pointerdown", function(e) { b2Dragging = true; b2Handle.setPointerCapture(e.pointerId); b2Handle.style.transition = "none"; e.preventDefault(); });
  b2Handle.addEventListener("pointermove", function(e) {
    if (!b2Dragging) return;
    var rect = b2Timeline.getBoundingClientRect(), pos = b2GetPositions();
    var clamped = Math.max(pos[0], Math.min(pos[B2_N - 1], e.clientY - rect.top));
    b2Handle.style.top = clamped + "px";
    b2GoTo(b2Nearest(clamped), false);
  });
  b2Handle.addEventListener("pointerup", function(e) {
    if (!b2Dragging) return;
    b2Dragging = false;
    b2GoTo(b2Nearest(e.clientY - b2Timeline.getBoundingClientRect().top), true);
  });
  window.addEventListener("resize", b2Layout);
  var b2Hovered = false;
  document.getElementById("timeline-block").addEventListener("mouseenter", function() { b2Hovered = true; });
  document.getElementById("timeline-block").addEventListener("mouseleave", function() { b2Hovered = false; });
  window.addEventListener("wheel", function(e) {
    if (!b2Hovered) return;
    var rect = document.getElementById("timeline-block").getBoundingClientRect();
    if (rect.top > 50) return;
    if (e.deltaY <= 0) return;
    if (b2ActiveStep === B2_N - 1) return;
    e.preventDefault();
    b2GoTo(Math.min(b2ActiveStep + 1, B2_N - 1));
  }, { passive: false });
  requestAnimationFrame(function() { b2Layout(); b2GoTo(0, false); });

  // Mobile: reveal steps via scroll instead of drag
  if (window.matchMedia('(pointer: coarse)').matches) {
    var b2Steps = b2ContentEl.querySelectorAll('.b2-step');
    var b2Obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var idx = parseInt(entry.target.dataset.b2idx);
          if (idx > b2ActiveStep) b2GoTo(idx, true);
        }
      });
    }, { threshold: 0.3 });
    b2Steps.forEach(function(el, i) {
      el.dataset.b2idx = i;
      b2Obs.observe(el);
    });
  }
})();
</script>
</body>
</html>
