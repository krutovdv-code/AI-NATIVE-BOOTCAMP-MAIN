<title>AI DRIVEN РАЗРАБОТКА — 12-недельный буткемп</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; border-radius: 0 !important; }
  
  :root {
    --bg: #f5f5f0;
    --ink: #0a0a0f;
    --accent: #f5a623;
    --ink10: rgba(10,10,15,0.10);
    --ink20: rgba(10,10,15,0.20);
    --ink40: rgba(10,10,15,0.40);
    --ink60: rgba(10,10,15,0.60);
    --ink05: rgba(10,10,15,0.05);
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
    font-variant-numeric: tabular-nums;
    text-rendering: optimizeLegibility;
    max-width: 1440px;
    margin: 0 auto;
    overflow-x: hidden;
  }

  h1, h2, h3, .display {
    font-family: 'Roboto Condensed', 'Arial Narrow', Arial, sans-serif !important;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    text-rendering: optimizeLegibility;
    font-variant-numeric: tabular-nums;
  }

  /* NAV — приклеена к верху при скролле (особенно на мобилке) */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 48px;
    background: rgba(245,245,240,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--ink10);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    max-width: 1440px;
    margin: 0 auto;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  .nav-logo {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .nav-center {
    font-size: 11px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--ink60);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .pulse-dot {
    width: 7px; height: 7px;
    background: var(--accent);
    border-radius: 50% !important;
    animation: pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  /* Левая часть навигации: лого + бургер */
  .nav-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  /* Бургер-меню — без окантовки и квадратика */
  .nav-burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    background: none;
    border: none;
    outline: none;
    box-shadow: none;
    cursor: pointer;
    position: relative;
    z-index: 101;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-burger:hover { background: transparent; }
  .nav-burger:focus { outline: none; box-shadow: none; }
  .nav-burger:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.is-open span:nth-child(2) { opacity: 0; }
  .nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .burger-overlay {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: rgba(10, 10, 15, 0.9);
    backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .burger-overlay.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .burger-panel {
    position: fixed;
    top: 48px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    padding: 24px 20px 32px;
    overflow: auto;
    display: flex;
    flex-direction: column;
    -webkit-overflow-scrolling: touch;
  }
  .burger-panel a,
  .burger-panel .burger-cta {
    display: block;
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--bg);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid rgba(245,245,240,0.15);
    transition: color 0.2s ease;
  }
  .burger-panel a:hover { color: var(--accent); }
  .burger-panel .burger-cta {
    margin-top: auto;
    padding-top: 24px;
    border-bottom: none;
    text-align: center;
    background: var(--accent);
    color: var(--ink);
    border-radius: 0;
    cursor: pointer;
    width: 100%;
    margin-left: 0;
    margin-right: 0;
  }
  .burger-panel .burger-cta:hover { opacity: 0.95; color: var(--ink); }

  /* SECTIONS */
  section { 
    padding: 80px 24px; 
    border-bottom: 1px solid var(--ink10);
    position: relative;
  }
  .section-grid {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0 32px;
    max-width: 1200px;
  }
  .section-grid > div:last-child { min-width: 0; }
  .section-num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 72px;
    color: var(--ink20);
    line-height: 1;
    user-select: none;
    padding-top: 6px;
  }

  /* HERO — контент отступает от фиксированного навбара, без обрезки сверху */
  #hero {
    padding: 88px 24px 80px;
    padding-top: max(88px, 56px + 48px);
    border-bottom: 1px solid var(--ink10);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .hero-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 24px;
  }
  .hero-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(56px, 8vw, 120px);
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    max-width: 1100px;
    margin-bottom: 40px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero-title .word { display: inline-block; opacity: 1; }
  .js .hero-title .word { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .js .hero-title .word.visible { opacity: 1; transform: translateY(0); }
  .hero-accent { color: var(--accent); }
  .partnership-mobile { display: none; }
  .hero-sub-row { display: block; }
  .hero-sub-row .hero-sub { margin-bottom: 56px; }
  .hero-sub {
    border-left: 2px solid var(--accent);
    padding-left: 24px;
    max-width: 640px;
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink60);
    margin-bottom: 56px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    max-width: 800px;
    border: 1px solid var(--ink10);
  }
  .stat-box {
    padding: 24px 28px;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
  }
  .stat-box:last-child { border-right: none; }
  .stat-num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 48px;
    line-height: 1;
    color: var(--accent);
    display: block;
    margin-bottom: 6px;
  }
  .stat-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink40);
  }

  /* CTA BUTTON */
  .cta-btn {
    display: inline-block;
    position: relative;
    overflow: hidden;
    padding: 16px 40px;
    background: var(--accent);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    cursor: pointer;
    border: none;
  }
  .cta-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }
  .cta-btn:hover::before { transform: translateX(0); }
  .cta-btn span { position: relative; z-index: 1; }
  .cta-btn:hover span { color: #f5f5f0; }

  /* ABOUT / LEGEND */
  .about-text {
    font-size: 15px;
    line-height: 1.8;
    color: var(--ink60);
    max-width: 720px;
    margin-bottom: 32px;
  }
  .about-text strong { color: var(--ink); font-weight: 600; }
  .bracket-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
    display: block;
  }

  /* FOR WHOM */
  .audience-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .audience-item {
    padding: 24px 28px;
    border-right: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .audience-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .audience-item.visible { opacity: 1; transform: translateY(0); }
  .audience-item:nth-child(even) { border-right: none; }
  .audience-item:nth-last-child(-n+2) { border-bottom: none; }
  .audience-num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 32px;
    color: var(--ink20);
    margin-bottom: 8px;
  }
  .audience-text {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }

  /* WHAT YOU LEARN */
  .learn-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .learn-item {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .learn-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .learn-item.visible { opacity: 1; transform: translateY(0); }
  .learn-item:nth-child(even) { border-right: none; }
  .learn-item:nth-last-child(-n+2) { border-bottom: none; }
  .learn-arrow {
    color: var(--accent);
    font-size: 18px;
    margin-bottom: 10px;
    display: block;
  }
  .learn-text {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .learn-text strong { color: var(--ink); }

  /* CURRICULUM */
  .module-block {
    margin-bottom: 2px;
    border: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .module-block { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .module-block.visible { opacity: 1; transform: translateY(0); }
  .module-header {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    align-items: center;
    padding: 20px 24px;
    background: var(--ink05);
  }
  .module-num-badge {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 22px;
    color: var(--accent);
  }
  .module-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .module-meta {
    font-size: 10px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    margin-left: 16px;
  }
  .module-body {
    padding: 24px;
    border-top: 1px solid var(--ink10);
  }
  .lesson-row {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--ink10);
    font-size: 12px;
  }
  .lesson-row > div:last-child { min-width: 0; }
  .lesson-row:last-child { border-bottom: none; }
  .lesson-num-sm {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 20px;
    color: var(--ink20);
    line-height: 1;
  }
  .lesson-name {
    font-weight: 600;
    font-size: 13px;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .lesson-desc {
    font-size: 11px;
    color: var(--ink60);
    line-height: 1.6;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .lesson-name { overflow-wrap: break-word; word-break: break-word; }
  .lesson-concepts {
    margin-top: 8px;
    font-size: 10px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-left: 2px solid var(--accent);
    padding-left: 10px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .module-body { overflow-wrap: break-word; word-break: break-word; }
  .module-title { overflow-wrap: break-word; word-break: break-word; }
  .bracket-label { overflow-wrap: break-word; word-break: break-word; }

  /* FORMAT */
  .format-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .format-item {
    padding: 32px 28px;
    border-right: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .format-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .format-item.visible { opacity: 1; transform: translateY(0); }
  .format-item:last-child { border-right: none; }
  .format-icon {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
    display: block;
  }
  .format-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 22px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .format-desc {
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }

  /* SECTION TITLES */
  .section-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(32px, 4vw, 56px);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: 40px;
  }

  /* FAQ */
  .faq-list { list-style: none; }
  .faq-item {
    padding: 24px 0;
    border-bottom: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .faq-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .faq-item.visible { opacity: 1; transform: translateY(0); }
  .faq-item:last-child { border-bottom: none; }
  .faq-q {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 16px;
    color: var(--ink);
    margin-bottom: 12px;
    line-height: 1.35;
    cursor: pointer;
    user-select: none;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .faq-q::after {
    content: '+';
    flex-shrink: 0;
    margin-left: 16px;
    font-size: 20px;
    line-height: 1.2;
    transition: transform 0.2s;
  }
  .faq-item.faq-open .faq-q::after { content: '−'; }
  .faq-a {
    font-size: 14px;
    line-height: 1.7;
    color: var(--ink60);
    display: none;
  }
  .faq-item.faq-open .faq-a { display: block; }
  .faq-a strong { color: var(--ink); }

  /* Путь разработчика (блок после О программе) */
  .path-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 48px;
    row-gap: 0;
    align-items: start;
    position: relative;
  }
  .path-columns::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 1px;
    background: var(--ink10);
    transform: translateX(-50%);
  }
  .path-col-header {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding-bottom: 14px;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .path-col-header.before { color: var(--ink40); border-bottom-color: var(--ink10); }
  .path-col-header.after { color: var(--accent); border-bottom-color: var(--accent); }
  .path-col-tag {
    font-size: 9px;
    padding: 2px 7px;
    border: 1px solid currentColor;
    letter-spacing: 0.15em;
  }
  .path-block {
    padding-bottom: 32px;
  }
  .path-columns > .path-block:nth-child(n+5) {
    border-top: 1px solid var(--ink10);
    padding-top: 28px;
  }
  .path-block:last-child,
  .path-block:nth-last-child(2) { padding-bottom: 0; }
  .path-block-num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--ink40);
    margin-bottom: 8px;
  }
  .path-block-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1.25;
    margin-bottom: 10px;
  }
  .path-block-text {
    font-size: 12.5px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .path-block-text em { font-style: italic; color: var(--ink); }
  @media (max-width: 640px) {
    .path-columns { grid-template-columns: 1fr; }
    .path-columns::after { display: none; }
    .path-columns .path-block:nth-child(odd):not(:first-child):not(:nth-child(3)) {
      margin-top: 32px;
      padding-top: 32px;
      border-top: 1px solid var(--ink10);
    }
  }

  /* CTA BLOCK */
  .cta-block {
    background: var(--ink);
    color: var(--bg);
    padding: 80px 24px;
    text-align: center;
  }
  .cta-block .section-title { color: var(--bg); margin-bottom: 16px; }
  .cta-widget-wrap { margin-top: 32px; min-height: 60px; }
  /* Модальное окно с виджетом заявки */
  .widget-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .widget-modal.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .widget-modal__box {
    position: relative;
    width: 100%;
    max-width: 480px;
    max-height: 90vh;
    overflow: auto;
