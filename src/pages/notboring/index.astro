  /* B2 — Путь разработчика (drag timeline) */
  #timeline-block { --b2-orange: #e8860a; --b2-muted: #6b6560; --b2-divider: #d4cec4; --b2-black: #1a1a1a; background: #f5f5f0; display: block; padding: 80px 24px; border-bottom: 1px solid rgba(10,10,15,0.10); }
  #timeline-block .b2-wrapper { display: flex; width: 100%; }
  #timeline-block .b2-timeline { position: relative; width: 64px; flex-shrink: 0; align-self: stretch; }
  #timeline-block .b2-track { position: absolute; top: 0; bottom: 0; left: 50%; width: 1px; background: var(--b2-divider); transform: translateX(-50%); }
  #timeline-block .b2-snap-dot { position: absolute; left: 50%; width: 10px; height: 10px; border-radius: 50% !important; background: var(--b2-divider); border: 2px solid #f5f5f0; transform: translate(-50%, -50%); transition: background 0.25s; cursor: pointer; }
  #timeline-block .b2-snap-dot.reached { background: var(--b2-black); }
  #timeline-block .b2-handle { position: absolute; left: 50%; width: 22px; height: 22px; border-radius: 50% !important; background: var(--b2-orange); transform: translate(-50%, -50%); cursor: grab; z-index: 10; box-shadow: 0 0 0 6px rgba(232,134,10,0.15); touch-action: none; transition: top 0.15s ease; }
  #timeline-block .b2-handle:active { cursor: grabbing; }
  #timeline-block .b2-era-label { position: absolute; right: calc(50% + 16px); font-size: 9px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; writing-mode: vertical-lr; transform: rotate(180deg) translateY(50%); white-space: nowrap; pointer-events: none; }
  #timeline-block .b2-era-label.before { color: var(--b2-muted); }
  #timeline-block .b2-era-label.after  { color: var(--b2-orange); }
  #timeline-block .b2-drag-hint { position: absolute; bottom: -24px; left: 50%; transform: translateX(-50%); font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--b2-muted); white-space: nowrap; opacity: 0.5; }
  #timeline-block .b2-content { flex: 1; padding-left: 40px; }
  @media (pointer: coarse) {
    #timeline-block .b2-timeline { display: none; }
