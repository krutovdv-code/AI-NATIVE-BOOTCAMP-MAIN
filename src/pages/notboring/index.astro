  }
  #timeline-block .b2-step { opacity: 0; transform: translateY(8px); transition: opacity 0.4s ease, transform 0.4s ease, border-color 0.4s ease; padding-bottom: 28px; margin-bottom: 28px; border-bottom: 1px solid transparent; }
  #timeline-block .b2-step.visible { opacity: 1; transform: translateY(0); border-bottom-color: var(--b2-divider); }
  #timeline-block .b2-step:last-child { padding-bottom: 0; margin-bottom: 0; border-bottom: none !important; }
  #timeline-block .b2-step-era { font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 6px; }
