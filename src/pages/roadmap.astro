document.getElementById('pTitle').textContent=el.querySelector('.node-name').textContent;
document.getElementById('pDesc').textContent=el.dataset.desc;
document.getElementById('pKw').innerHTML=kw.map(k=>'<span class="panel-kw">'+k.trim()+'</span>').join('');
const pl=document.getElementById('pLinks'),pe=document.getElementById('pEmpty');
if(links.length){pl.innerHTML=links.map(l=>'<li><a href="'+l.url+'" target="_blank" rel="noopener">'+l.title+'</a></li>').join('');pl.style.display='block';pe.style.display='none'}
else{pl.style.display='none';pe.style.display='block'}
pn.classList.add('active');ov.classList.add('active')}
function closePanel(){pn.classList.remove('active');ov.classList.remove('active')}
document.querySelectorAll('.node').forEach(c=>c.addEventListener('click',()=>openPanel(c)));
document.getElementById('pc').addEventListener('click',closePanel);
ov.addEventListener('click',closePanel);
document.addEventListener('keydown',e=>{if(e.key==='Escape')closePanel()});
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')})},{threshold:.1});
document.querySelectorAll('.cat-row').forEach(c=>obs.observe(c));
</script>
</body>
</html>
