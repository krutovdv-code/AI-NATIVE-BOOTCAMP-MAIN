<style is:global>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;border-radius:0!important}
  :root{--bg:#f5f5f0;--ink:#0a0a0f;--accent:#f5a623;--ink05:rgba(10,10,15,.05);--ink10:rgba(10,10,15,.1);--ink20:rgba(10,10,15,.2);--ink40:rgba(10,10,15,.4);--ink60:rgba(10,10,15,.6);--node-bg:#fff;--spine:#d4cec4}
  html{font-size:16px;scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ink);font-family:'JetBrains Mono',monospace;max-width:960px;margin:0 auto;overflow-x:hidden}
  h1,h2,h3{font-family:'Roboto Condensed',sans-serif!important;font-weight:900;text-transform:uppercase;letter-spacing:-.03em;line-height:.95}

  /* HEADER */
  header{padding:80px 24px 48px;border-bottom:1px solid var(--ink10);text-align:center}
  header h1{font-size:clamp(40px,6vw,72px);line-height:.92;margin-bottom:20px}
  .accent{color:var(--accent)}
  header p{font-size:12px;line-height:1.7;color:var(--ink60);max-width:520px;border-left:2px solid var(--accent);padding-left:20px;margin:0 auto;text-align:left}
  header .header-tg{border:none;padding-left:0;margin-top:20px;color:var(--ink60)}
  header .header-tg a{color:var(--accent);text-decoration:none;border-bottom:1px solid var(--accent)}
  header .header-tg a:hover{color:var(--ink)}

  /* TREE */
  .tree{position:relative;padding:0 24px 60px}

  /* Central spine */
  .tree::before{content:'';position:absolute;left:50%;top:0;bottom:60px;width:1px;background:var(--spine);transform:translateX(-.5px)}

  /* CATEGORY ROW */
  .cat-row{position:relative;padding:48px 0 0;opacity:0;transform:translateY(20px);transition:opacity .5s ease,transform .5s ease}
  .cat-row.visible{opacity:1;transform:translateY(0)}

  /* Category hub on spine */
  .cat-hub{position:relative;z-index:3;width:max-content;margin:0 auto 24px;padding:10px 24px;background:var(--ink);color:var(--bg);font-family:'Roboto Condensed',sans-serif!important;font-weight:900;font-size:clamp(14px,2vw,17px);text-transform:uppercase;letter-spacing:.02em;text-align:center;line-height:1.2}

  /* Nodes container */
  .nodes{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;padding-bottom:8px;position:relative}

  /* Node */
  .node{position:relative;background:var(--node-bg);border:1px solid var(--ink10);padding:14px 18px;cursor:pointer;transition:all .15s;min-width:140px;max-width:220px;flex:1 1 140px}
  .node:hover{border-color:var(--ink);background:#ebe6dc}
  .node-name{font-size:12px;font-weight:600;color:var(--ink);line-height:1.35}
  .node-sub{font-size:10px;color:var(--ink40);line-height:1.4;margin-top:2px}
  .node-arrow{position:absolute;top:12px;right:12px;color:var(--accent);font-size:12px;opacity:0;transition:opacity .15s}
  .tg-cta{max-width:520px;margin:60px auto 40px;padding:24px 28px;border:2px solid var(--accent);background:rgba(245,166,35,0.05);text-align:center;display:block;text-decoration:none;color:var(--ink);transition:background .15s}
  .tg-cta:hover{background:rgba(245,166,35,0.12)}
  .tg-cta-label{font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:var(--ink60);margin-bottom:8px}
  .tg-cta-text{font-size:15px;font-weight:600;color:var(--ink)}
  .tg-cta-text span{color:var(--accent);border-bottom:1px solid var(--accent)}
  .node:hover .node-arrow{opacity:1}

  /* Connector dots on spine for each category */
  .cat-row::after{content:'';position:absolute;left:50%;top:48px;width:9px;height:9px;background:var(--accent);transform:translate(-50%,0);z-index:2;border:2px solid var(--bg)}

  /* Connector lines from nodes to spine */
  .connector-line{position:absolute;left:50%;top:0;width:1px;height:24px;background:var(--spine);transform:translateX(-.5px)}

  /* PANEL */
  .panel-overlay{display:none;position:fixed;inset:0;background:rgba(10,10,15,.3);z-index:100}
  .panel-overlay.active{display:block}
  .panel{position:fixed;right:-480px;top:0;bottom:0;width:460px;max-width:92vw;background:var(--bg);border-left:1px solid var(--ink10);z-index:101;padding:40px 32px;overflow-y:auto;transition:right .3s ease}
  .panel.active{right:0}
  .panel-close{position:absolute;top:16px;right:16px;background:none;border:1px solid var(--ink10);color:var(--ink40);width:32px;height:32px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;font-family:'JetBrains Mono',monospace;transition:all .15s}
  .panel-close:hover{color:var(--ink);border-color:var(--ink20)}
  .panel-cat{font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--accent);margin-bottom:12px}
  .panel h2{font-size:24px;margin-bottom:16px;padding-right:48px;line-height:1.05}
  .panel-desc{font-size:12px;line-height:1.8;color:var(--ink60);margin-bottom:28px;border-left:2px solid var(--accent);padding-left:16px}
  .panel-section{font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--ink40);margin-bottom:12px}
  .panel-keywords{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:28px}
  .panel-kw{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ink40);border:1px solid var(--ink10);padding:4px 10px;background:var(--ink05)}
  .panel-links{list-style:none;margin-bottom:28px}
  .panel-links li{margin-bottom:6px}
  .panel-links a{font-size:12px;color:var(--ink);text-decoration:none;display:flex;align-items:center;gap:8px;transition:color .15s}
  .panel-links a:hover{color:var(--accent)}
  .panel-links a::before{content:'→';color:var(--accent);font-size:12px}
  .panel-empty{font-size:11px;color:var(--ink40);font-style:italic}

  footer{padding:32px 24px;display:flex;justify-content:space-between;font-size:10px;color:var(--ink40);text-transform:uppercase;letter-spacing:.1em;border-top:1px solid var(--ink10)}

  .node[data-id="multiexpert"]{min-width:180px}
  .node[data-id="det-refactoring"]{min-width:220px;max-width:280px}

  @media(max-width:600px){
    .nodes{flex-direction:column;align-items:center}
    .node{max-width:100%;min-width:0;width:100%}
  }
</style>
