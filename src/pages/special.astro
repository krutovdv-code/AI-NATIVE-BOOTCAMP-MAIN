  }
  .footer-requisites a { color: var(--ink40); text-decoration: underline; }
  .footer-requisites a:hover { color: var(--ink); }
  @media (max-width: 600px) {
    .footer-top { flex-direction: column; }
    .footer-links { gap: 32px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .footer-requisites { grid-template-columns: 1fr; }
  }

  /* SCROLL REVEAL — по умолчанию видно (без JS); с JS скрыто до появления в viewport */
  .reveal { opacity: 1; }
  .js .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }
  .js .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Бургер — с 992px */

  @media (max-width: 768px) {
    .hero-stats { grid-template-columns: repeat(3, 1fr); max-width: 100%; }
    .stat-box { aspect-ratio: auto; padding: 16px 14px; }
    .stat-num { font-size: 36px; }
    .audience-grid { grid-template-columns: 1fr; }
    .learn-list { grid-template-columns: 1fr; }
    .format-grid { grid-template-columns: repeat(2, 1fr); }
    .hero-title { font-size: clamp(28px, 9vw, 52px); }
    .hero-sub { padding-left: 16px; font-size: 13px; }
    #hero {
      padding: 108px 20px 80px;
      padding-bottom: max(80px, calc(24px + env(safe-area-inset-bottom, 0)));
      min-height: auto;
    }
    .module-header { grid-template-columns: 56px 1fr; padding: 16px 16px; }
    .module-meta { grid-column: 1 / -1; white-space: normal; margin-left: 0; margin-top: 8px; }
    .module-body { padding: 16px; }
    .lesson-row { grid-template-columns: 36px 1fr; gap: 12px; padding: 12px 0; }
  }
  @media (max-width: 480px) {
    .hero-title { font-size: clamp(24px, 8vw, 40px); }
    section { padding: 48px 16px; padding-bottom: max(48px, calc(16px + env(safe-area-inset-bottom, 0))); }
    .format-grid { grid-template-columns: 1fr; }
  }
  body { padding-bottom: env(safe-area-inset-bottom, 0); }

  /* FEEDBACK CAROUSEL */
  .feedback-carousel-wrap { margin-top: 48px; }
  .feedback-track-outer {
    position: relative;
    overflow: hidden;
  }
  .feedback-track {
    display: flex;
    align-items: stretch;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    cursor: grab;
    user-select: none;
    touch-action: pan-y;
    border: 1px solid var(--ink10);
  }
  .feedback-track:active { cursor: grabbing; }
  .feedback-track::-webkit-scrollbar { display: none; }
  .feedback-card {
    flex-shrink: 0;
    scroll-snap-align: start;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .feedback-card:last-child { border-right: none; }
  .feedback-card--screenshot { width: 240px; }
  .feedback-card--video { width: 420px; }
  .feedback-card--text { width: 442px; padding: 32px; }
  .feedback-card-bottom { margin-top: auto; }
  .feedback-placeholder {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }
  .feedback-placeholder-icon {
    font-size: 24px;
    color: var(--ink20);
    line-height: 1;
  }
  .feedback-placeholder-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink20);
  }
  .feedback-text-quote {
    font-size: 14px;
    line-height: 1.75;
    color: var(--ink40);
  }
  .feedback-text-quote::before { content: '«'; }
  .feedback-text-quote::after { content: '»'; }
  .feedback-text-author {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 24px;
  }
  .feedback-text-avatar {
    width: 80px;
    height: 80px;
    background: var(--ink10);
    flex-shrink: 0;
    object-fit: cover;
  }
  .feedback-text-name {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--ink);
    line-height: 1.2;
  }
  .feedback-text-role {
    font-size: 10px;
    color: var(--ink60);
    margin-top: 3px;
    letter-spacing: 0.05em;
  }
  .feedback-stack {
    font-size: 10px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.6;
    margin-top: 16px;
    border-left: 2px solid var(--accent);
    padding-left: 10px;
  }
  .feedback-company {
    font-size: 10px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 6px;
  }
  .feedback-controls {
    display: flex;
    gap: 0;
    margin-top: 16px;
    position: relative;
    height: 48px;
    align-items: center;
  }
  .feedback-cta {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  @media (max-width: 640px) {
    .feedback-company {
    font-size: 10px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 6px;
  }
  .feedback-controls {
      flex-wrap: wrap;
      height: auto;
      gap: 12px;
    }
    .feedback-cta {
      position: static;
      transform: none;
      width: 100%;
    }
    .feedback-cta span { display: block; text-align: center; }
  }
  .feedback-arrow {
    width: 48px;
    height: 48px;
    border: 1px solid var(--ink10);
    background: var(--ink05);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: color 0.2s ease;
  }
  .feedback-arrow + .feedback-arrow { margin-left: -1px; }
  .feedback-arrow::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }
  .feedback-arrow:hover:not(:disabled)::before { transform: translateX(0); }
  .feedback-arrow span { position: relative; z-index: 1; }
  .feedback-arrow:disabled { opacity: 0.25; cursor: default; }
  @media (max-width: 768px) {
    .feedback-card--text { width: 364px; padding: 24px; }
  }

  /* COMMITTEE INTRO */
  .committee-intro { margin: 20px 0 28px; }
  .committee-intro-text { font-family: 'Roboto Condensed', sans-serif; text-transform: uppercase; font-weight: 600; font-size: 56px; line-height: 1.3; color: black; margin: 0; }
  .committee-intro-accent { font-family: 'Roboto Condensed', sans-serif; text-transform: uppercase; font-weight: 600; font-size: 56px; line-height: 1.3; color: var(--accent); margin: 0; }
  /* COMMITTEE */
  .committee-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .committee-card {
    border-right: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    overflow: hidden;
  }
  .committee-card:nth-child(4n) { border-right: none; }
  .committee-card:nth-last-child(-n+4) { border-bottom: none; }
  .committee-photo-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  .committee-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
  }
  .committee-card:hover .committee-photo {
transform: scale(1.04);
  }
  .committee-info {
    padding: 12px 14px;
    border-top: 1px solid var(--ink10);
  }
  .committee-name {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: clamp(11px, 1.1vw, 16px);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
    word-break: break-word;
    overflow-wrap: break-word;
    line-height: 1.1;
  }
  .committee-role {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.3;
    margin-bottom: 8px;
  }
  .committee-quote {
    font-size: 12px;
    line-height: 1.5;
    color: var(--ink60);
    font-style: italic;
  }


  /* AUTHORS */
  .authors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--ink10);
    margin-bottom: 2px;
  }
  .author-card {
    border-right: 1px solid var(--ink10);
    overflow: hidden;
  }
  .author-card:last-child { border-right: none; }
  .author-photo-wrap {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--ink05);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .author-photo-placeholder {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 64px;
    color: var(--ink20);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    user-select: none;
  }
  .author-info {
    padding: 16px;
    border-top: 1px solid var(--ink10);
  }
  .author-name {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(14px, 1.4vw, 22px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 6px;
    line-height: 1.05;
    word-break: break-word;
    overflow-wrap: break-word;
  }
  .author-company {
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .author-tag {
    display: inline-block;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink40);
    border: 1px solid var(--ink10);
    padding: 3px 8px;
    margin-top: 10px;
  }
  .section-divider-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink40);
    padding: 16px 0 12px;
    border-top: 1px solid var(--ink10);
    margin-top: 40px;
    margin-bottom: 0;
    display: block;
  }


  @media (max-width: 600px) {
    .authors-grid { grid-template-columns: 1fr; }
    .author-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .author-card:last-child { border-bottom: none; }
    .committee-grid { grid-template-columns: repeat(2, 1fr); }
    .committee-card:nth-child(2n) { border-right: none; }
    .committee-card:nth-child(4n) { border-right: none; }
    .committee-card:nth-last-child(-n+2) { border-bottom: none; }
    .committee-card:nth-last-child(-n+4) { border-bottom: 1px solid var(--ink10); }
    .author-name { font-size: 20px; }
    .committee-name { font-size: 13px; }
  }
  @media (min-width: 601px) and (max-width: 900px) {
    .committee-grid { grid-template-columns: repeat(2, 1fr); }
    .committee-card:nth-child(2n) { border-right: none; }
    .committee-card:nth-child(4n) { border-right: 1px solid var(--ink10); }
    .committee-card:nth-last-child(-n+4) { border-bottom: 1px solid var(--ink10); }
    .committee-card:nth-last-child(-n+2) { border-bottom: none; }
    .author-name { font-size: 18px; }
    .committee-name { font-size: 13px; }
  }
  @media (min-width: 901px) {
    .committee-grid { border-right: none; border-bottom: none; }
    .committee-card:nth-child(4n) { border-right: 1px solid var(--ink10); }
    .committee-card:nth-last-child(-n+4) { border-bottom: 1px solid var(--ink10); }
  }


  .author-bio {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--ink10);
  }
  .author-bio-item {
    font-size: 11px;
    line-height: 1.6;
    color: var(--ink60);
    padding: 5px 0;
    border-bottom: 1px solid var(--ink10);
    padding-left: 10px;
    border-left: 2px solid var(--ink10);
    margin-bottom: 4px;
  }
  .author-bio-item:last-child { border-bottom: none; margin-bottom: 0; }
  .author-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
  }
  .author-card:hover .author-photo { transform: scale(1.04); }



  /* PRICING */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 1200px;
    border: 1px solid var(--ink10);
    margin-top: 48px;
  }
  .pricing-card {
    padding: 40px 36px;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
    display: flex;
    flex-direction: column;
  }
  .pricing-card:last-child { border-right: none; }
  .pricing-card-tier {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink40);
    margin-bottom: 20px;
    display: block;
  }
  .pricing-card-name {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 26px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    min-height: 33px;
  }
  .pricing-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }
  .pricing-card-header .pricing-card-name {
    margin-bottom: 0;
  }
  .pricing-badge {
    background: var(--bg);
    color: var(--ink);
    text-align: center;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.5;
    padding: 8px 14px;
    flex-shrink: 0;
    margin-left: 16px;
  }
  .pricing-price {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 28px;
    line-height: 1;
    color: var(--accent);
    display: block;
    margin-bottom: 4px;
  }
  .pricing-price-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink40);
    display: block;
    margin-bottom: 12px;
  }
  .pricing-alt {
    font-size: 13px;
    color: var(--ink60);
    padding: 12px 0;
    border-top: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    margin-bottom: 28px;
  }
  .pricing-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pricing-bullet {
    font-size: 13px;
    color: var(--ink20);
    line-height: 1.6;
    min-height: 1.6em;
    padding-left: 20px;
    position: relative;
  }
  .pricing-bullet::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--ink20);
  }
  .pricing-card--featured { position: relative; }
  .cta-block .pricing-card--featured {
    background: rgba(245,245,240,0.12);
  }
  .pricing-price-note {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink40);
    display: block;
    margin-bottom: 28px;
    line-height: 1.5;
  }
  .cta-block .pricing-price-note { color: rgba(245,245,240,0.45); }
  .pricing-footer {
    max-width: 1200px;
    margin: 16px auto 0;
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(245,245,240,0.12);
    flex-wrap: wrap;
  }
  .pricing-footer-item {
    padding: 14px 24px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(245,245,240,0.55);
    border-right: 1px solid rgba(245,245,240,0.12);
    flex: 1;
    cursor: default;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .pricing-footer-item:last-child { border-right: none; }
  .pricing-footer-item:hover {
    background: var(--bg);
    color: var(--ink);
  }

  /* PRICING — TEAM CARD */
  .pricing-card--teams {
    background: rgba(245,245,240,0.04);
  }
  .pricing-card--teams .pricing-card-name { color: rgba(245,245,240,1); }
  .pricing-card--teams .pricing-tagline { color: rgba(245,245,240,1); }
  .pricing-price--teams {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(22px, 2vw, 32px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 6px;
    display: block;
  }
  .pricing-price-note--teams {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(245,245,240,0.35);
    display: block;
    margin-bottom: 24px;
  }
  .pricing-tagline {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(245,245,240,1);
    margin-bottom: 24px;
    padding-bottom: 20px;
    \border-bottom: 1px solid rgba(245,245,240,0.1);
  }
  .pricing-unique { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .pricing-unique-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(245,245,240,0.7);
    padding-left: 20px;
    position: relative;
  }
  .pricing-unique-item::before {
    content: '\2014';
    position: absolute;
    left: 0;
    color: rgba(245,245,240,0.3);
  }
  .pricing-unique-item--accent {
    border-left: 2px solid var(--accent);
    padding-left: 14px;
  }
  .pricing-unique-item--accent::before { display: none; }
  .pricing-shared {
    max-width: 1200px;
    margin: 0 auto;
    border: 1px solid rgba(245,245,240,0.12);
    border-top: none;
    padding: 20px 36px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .pricing-shared-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(245,245,240,1);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .pricing-shared-items { list-style: none; display: flex; flex-wrap: wrap; flex: 1; }
  .pricing-shared-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: rgba(245,245,240,0.55);
    padding: 4px 16px;
    border-right: 1px solid rgba(245,245,240,0.12);
  }
  .pricing-shared-item:last-child { border-right: none; }
  @media (max-width: 640px) {
    .pricing-shared { padding: 16px 20px; flex-direction: column; gap: 12px; }
    .pricing-shared-items { flex-direction: column; }
    .pricing-shared-item { border-right: none; padding: 6px 0; }
  }
    @media (max-width: 900px) {
    .pricing-grid { grid-template-columns: 1fr; }
    .pricing-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .pricing-card:last-child { border-bottom: none; }
    .pricing-price { font-size: 22px; }
    .pricing-card { padding: 28px 20px; }
    .referral-block { padding: 28px 20px; }
    .referral-col { padding: 16px 14px; }
    .referral-col-value { font-size: 26px; }
    .nav-cta { padding: 0 16px; font-size: 10px; }
    .nav-logo { display: none; }
    .nav-announce-line2 { display: none; }
    .nav-announce-line1 { font-size: 8px; }
    .nav-dot { width: 5px; height: 5px; }
    nav { display: flex; flex-direction: row; flex-wrap: nowrap; align-items: center; }
    .nav-left { order: 1; flex: 0 0 auto; }
    .nav-center { order: 2; flex: 1 1 0; min-width: 0; overflow: hidden; justify-content: center; }
    .nav-right { order: 3; flex: 0 0 auto; }
  }

  /* SECTION SUB-TITLE (h3 внутри секций) */
  .section-sub-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(20px, 2.2vw, 30px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-top: 48px;
    margin-bottom: 20px;
    color: var(--ink);
  }

  /* TERMINAL STATUS LINE */
  .terminal-status {
    margin-bottom: 32px;
    border-top: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
  }
  .terminal-status__bar {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    background: none;
    border: none;
    padding: 9px 0;
    cursor: pointer;
    text-align: left;
    transition: opacity 0.15s;
  }
  .terminal-status__bar:hover { opacity: 0.75; }
  .terminal-status__overflow {
    flex: 1;
    min-width: 0;
    overflow: hidden;
  }
  .terminal-status__track {
    display: inline-flex;
    white-space: nowrap;
  }
  .terminal-status__text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink40);
    padding-right: 64px;
    display: inline-block;
  }
  .terminal-status__text:last-child { display: none; }
  .terminal-status__prompt { color: var(--accent); }
  .terminal-status__cursor {
    color: var(--accent);
    animation: termBlink 1s step-end infinite;
    margin-left: 2px;
  }
  .terminal-status.is-open .terminal-status__cursor { animation: none; opacity: 1; }
  .terminal-status__hint {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink20);
    flex-shrink: 0;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .terminal-status__bar:hover .terminal-status__hint { color: var(--ink40); }
  .terminal-status.is-open .terminal-status__hint { color: var(--accent); }
  @keyframes termBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* TERMINAL NAV */
  .terminal-nav {
    border-top: 1px solid var(--ink10);
    padding: 6px 0 12px 18px;
  }
  .terminal-nav[hidden] { display: none; }
  .terminal-nav__item {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 7px 0;
    text-decoration: none;
    color: var(--ink60);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.15s;
    position: relative;
  }
  .terminal-nav__item.visible { opacity: 1; transform: translateY(0); }
  .terminal-nav__item:hover { color: var(--ink); }
  .terminal-nav__item.is-focused { color: var(--ink); }
  .terminal-nav__item.is-focused::before {
    content: '>';
    position: absolute;
    left: -16px;
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    top: 50%;
    transform: translateY(-50%);
    line-height: 1;
  }
  .terminal-nav__cmd {
    color: var(--accent);
    min-width: 110px;
    flex-shrink: 0;
    font-size: 11px;
  }
  .terminal-nav__item--cta .terminal-nav__label { color: var(--accent); }
  .terminal-nav__item--cta:hover .terminal-nav__label { color: var(--ink); }

  @media (max-width: 640px) {
    .terminal-status__text:last-child { display: inline-block; }
    .terminal-status.is-open .terminal-status__track { animation-play-state: paused; }
    .terminal-status__track { animation: termScroll 14s linear infinite; }
    @keyframes termScroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  }

  /* PREREQ HINT POPOVER */
  .prereq-hint-wrap {
    position: relative;
    display: inline-block;
    margin-top: 16px;
  }
  .prereq-hint-popover {
    position: absolute;
    top: 50%;
    left: calc(100% + 12px);
    transform: translateY(-50%);
    z-index: 50;
    width: min(380px, calc(100vw - 48px));
    background: var(--bg);
    border: 1px solid var(--ink20);
    border-left: 3px solid var(--accent);
    padding: 14px 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .prereq-hint-popover[hidden] { display: none; }
  @media (max-width: 640px) {
    .prereq-hint-popover {
      top: calc(100% + 6px);
      left: 0;
      transform: none;
    }
  }

  /* ROLE CARDS — для кого */
  .roles-block {
    margin: 40px 0 0px;
  }
  .roles-primary {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1px solid var(--ink10);
    margin-bottom: 12px;
  }
  .role-card {
    padding: 24px 28px;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .role-card:last-child { border-right: none; }
  .role-card__num {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    font-family: 'JetBrains Mono', monospace;
  }
  .role-card__title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .roles-primary { grid-template-columns: 1fr; }
    .role-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .role-card:last-child { border-bottom: none; }
  }

  /* HERO ACTIONS */
  .hero-actions {
    display: flex;
    align-items: stretch;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-invite {
    display: flex;
    align-items: center;
    font-family: 'JetBrains Mono', monospace !important;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.8rem;
    background: var(--ink);
    color: var(--bg);
    border: 1px solid var(--ink);
    border-radius: 0 !important;
    padding: 16px 24px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.12s, color 0.12s;
  }
  .btn-invite:hover { background: var(--accent); color: var(--ink); }

  /* VIDEO MODAL */
  .video-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    background: rgba(10,10,15,0.85);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .video-modal.is-open { opacity: 1; visibility: visible; pointer-events: auto; }
  .video-modal__box {
    position: relative;
    width: 100%;
    max-width: 620px;
    background: var(--ink);
    padding: 44px 32px 32px;
    overflow-y: auto;
    max-height: 92vh;
  }
  .video-modal__close {
    position: absolute;
    top: 12px; right: 12px;
    background: transparent;
    border: 1px solid rgba(245,245,240,0.2);
    color: rgba(245,245,240,0.5);
    width: 32px; height: 32px;
    cursor: pointer;
    font-size: 18px;
    line-height: 32px;
    text-align: center;
    transition: color 0.2s, border-color 0.2s;
  }
  .video-modal__close:hover { color: var(--bg); border-color: rgba(245,245,240,0.6); }
  .video-modal__videos { display: flex; flex-direction: column; gap: 28px; }
  .video-modal__label {
    font-family: 'JetBrains Mono Black', monospace;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--black);
    margin-bottom: 10px;
  }
  .video-modal__ratio {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #000;
  }
  .video-modal__ratio iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
  }
  @media (max-width: 640px) {
    .hero-actions { flex-direction: column; align-items: stretch; }
    .btn-invite { justify-content: center; padding: 12px 20px; font-size: 11px; letter-spacing: 0.06em; }
    .video-modal__box { padding: 44px 16px 24px; }
  }

  /* WHY-NOW TABS (about) */
  .tabs-card { width: 100%; max-width: none; margin-top: 40px; }
  .tabs-nav {
    display: flex;
    gap: 4px;
    align-items: flex-end;
  }
  .tab-btn {
    flex: 1 1 0;
    min-width: 0;
    text-align: left;
    background: transparent;
    border: 1px solid var(--ink10);
    border-bottom: none;
    padding: 14px 16px 16px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: var(--ink40);
    font-family: inherit;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tab-btn:hover:not(.is-active) { background: var(--ink05); color: var(--ink60); }
  .tab-num {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 22px;
    line-height: 1;
    color: var(--ink20);
  }
  .tab-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.4;
    word-break: break-word;
  }
  .tab-btn.is-active {
    background: var(--ink05);
    color: var(--ink);
    margin-bottom: -1px;              /* перекрываем верхнюю границу тела */
    position: relative;
    z-index: 2;
  }
  .tab-btn.is-active .tab-num { color: var(--accent); }

  .tabs-body {
    background: var(--ink05);
    border: 1px solid var(--ink10);
    padding: 40px 44px;
    display: grid;                     /* все панели в одной ячейке → высота = самой высокой */
  }

  /* Все панели наложены друг на друга: высота тела фиксируется по самой высокой,
     низ не «прыгает» при переключении. Неактивные скрыты, но занимают место. */
  .tab-panel { grid-area: 1 / 1; visibility: hidden; }
  .tab-panel.is-active { visibility: visible; }

  .panel-title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(24px, 3vw, 34px);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 32px;
  }

  .panel-lead {
    font-size: 14px;
    line-height: 1.8;
    color: var(--ink60);
  }
  .panel-lead + .panel-lead { margin-top: 18px; }

  .author-list {
    list-style: none;
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .author-list + .panel-lead { margin-top: 18px; }
  .author-item {
    position: relative;
    padding-left: 26px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink60);
  }
  .author-item::before {
    content: '→';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 600;
  }

  .panel-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 32px;
    padding: 13px 26px;
    background: var(--ink);
    color: var(--bg);
    border: 1px solid var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .panel-btn:hover { background: var(--accent); color: var(--ink); border-color: var(--accent); }

  .panel-item { margin-bottom: 24px; }
  .panel-item:last-child { margin-bottom: 0; }
  .item-h {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 14px;
    color: var(--ink);
    margin-bottom: 6px;
    line-height: 1.4;
  }
  .item-text {
    font-size: 14px;
    line-height: 1.8;
    color: var(--ink60);
  }
  a.item-cited {
    display: block;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  a.item-cited:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-underline-offset: 3px;
  }
  .cite-arrow { color: var(--accent); white-space: nowrap; font-weight: 600; }

  @media (max-width: 640px) {
    .tabs-body { padding: 28px 20px; }
    .tab-btn { align-items: center; padding: 12px 8px; }
    .tab-label { display: none; }        /* на мобилке — только номера */
  }

  /* ===== STREAMS (галерея студентов, #feedback) ===== */
  .streams { margin-top: 56px; }
  .streams-nav { display: flex; gap: 4px; align-items: stretch; }
  .stream-btn {
    flex: 1 1 0;
    min-width: 0;
    text-align: left;
    background: transparent;
    border: 1px solid var(--ink10);
    padding: 16px 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--ink40);
    font-family: inherit;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .stream-btn__main { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .stream-btn__label {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 20px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    color: var(--ink);
  }
  .stream-btn__note {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--accent);
    line-height: 1.2;
  }
  .stream-btn__caret {
    flex-shrink: 0;
    font-size: 14px;
    line-height: 1;
    transition: transform 0.3s ease;
  }
  .stream-btn:not(:disabled):hover { background: var(--ink05); }
  .stream-btn:disabled { cursor: default; }
  .stream-btn:disabled .stream-btn__label { color: var(--ink40); }
  /* «нажатое» состояние — залито тёмным, видно что нажато и нужно нажать снова */
  .stream-btn.is-open {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--bg);
  }
  .stream-btn.is-open .stream-btn__label { color: var(--bg); }
  .stream-btn.is-open .stream-btn__caret { transform: rotate(180deg); }
  /* при наведении на открытую кнопку фон светлеет — возвращаем тёмный текст для читаемости */
  .stream-btn.is-open:hover { color: var(--ink); }
  .stream-btn.is-open:hover .stream-btn__label { color: var(--ink); }

  /* панель-аккордеон: плавная высота через grid-template-rows 0fr → 1fr */
  .stream-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
  }
  .stream-panel.is-open { grid-template-rows: 1fr; margin-top: 4px; }
  .stream-panel__inner { overflow: hidden; }
  .stream-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    background: var(--ink10);
    border: 1px solid var(--ink10);
  }
  .student {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 10px;
    padding: 18px 8px;
    background: var(--bg);
  }
  .student__img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    filter: grayscale(1);
    transition: filter 0.2s ease;
  }
  .student:hover .student__img { filter: grayscale(0); }
  .student__name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    line-height: 1.35;
    color: var(--ink60);
  }
  .student--empty { background: var(--ink05); }

  @media (max-width: 900px) {
    .stream-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 600px) {
    .stream-grid { grid-template-columns: repeat(3, 1fr); }
    .stream-btn { padding: 14px; }
    .stream-btn__label { font-size: 16px; }
    .student--empty { display: none; }
  }

  /* ===== PRICING / FORMATS (тёмная инверсия, #register) ===== */
  .pricing-section {
    /* фон — во всю ширину страницы (как и остальные <section>), содержимое — внутри .pricing-inner */
    padding: 80px 24px;
    background: var(--ink);
    color: var(--bg);
    font-variant-numeric: tabular-nums;
  }
  .pricing-inner { max-width: 1200px; margin: 0 auto; }
  .pricing-section .section-title { color: var(--bg); margin-bottom: 24px; }
  .pricing-section .bracket-label { margin-bottom: 12px; }

  /* вводный блок секции — заголовок и подводка по центру */
  .pricing-head { text-align: center; }

  .pricing-lead {
    max-width: 680px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--cream-muted);
    margin: 0 auto 48px;
  }

  .pricing-main { max-width: 70%; margin: 0 auto 32px; border: 1px solid var(--cream-border); }
  .pricing-main__head { padding: 40px 40px 32px; border-bottom: 1px solid var(--cream-border); }
  .pricing-main__head-row { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 16px; }
  .pricing-main__head-row .pricing-main__title { margin: 0; }
  .pricing-main__title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--bg);
    margin: 0 0 16px;
  }
  .pricing-main__desc { font-size: 14px; line-height: 1.7; color: var(--cream-muted); max-width: 560px; margin: 0; }
  .pricing-main__desc + .pricing-main__desc { margin-top: 12px; }

  .pricing-value-list { list-style: none; margin: 0; padding: 0; }
  .pricing-value-list li {
    position: relative;
    padding: 20px 40px 20px 64px;
    border-bottom: 1px solid var(--cream-border);
    font-size: 14px;
    line-height: 1.6;
    color: var(--bg);
  }
  .pricing-value-list li::before {
    content: '→';
    position: absolute;
    left: 40px;
    top: 20px;
    color: var(--accent);
    font-weight: 600;
  }
  .pricing-value-list li:last-child { border-bottom: none; }
  .pricing-value-list li.is-placeholder { color: var(--accent); }

  /* вложенный список материалов курса — табуляция диагональной стрелкой ↗ */
  .pricing-sublist { list-style: none; margin: 10px 0 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .pricing-sublist li {
    position: relative;
    padding: 0 0 0 22px;
    border-bottom: none;
    font-size: 13px;
    line-height: 1.5;
    color: var(--cream-muted);
  }
  .pricing-sublist li::before {
    content: '↗';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
  }
  .pricing-value-list li.is-price { padding-bottom: 40px; }      /* тот же вес, что раньше давал .pricing-main__cta */
  .pricing-value-list li.is-price::before { content: none; }  /* цена — без маркера-стрелки */
  .pricing-value-list .price-num {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 24px;
    letter-spacing: -0.01em;
    color: var(--accent);
  }
  .pricing-value-list .price-unit { font-size: 13px; color: var(--cream-muted); }

  .pricing-price-row { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; margin-bottom: 20px; }
  .pricing-value-list li.is-price .cta-btn { font-size: 14.4px; } /* 12px + 20%, только для этой кнопки */

  /* трёхколоночная полоса под ценой и СТА — тот же стиль, что у .pricing-footer */
  .pricing-price-footer {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--cream-border);
    flex-wrap: wrap;
    margin-left: -64px;   /* bleed до края .pricing-main — гасим левый паддинг .is-price (64px, под стрелку) */
    margin-right: -40px;  /* гасим правый паддинг .is-price (40px) */
    margin-bottom: -40px; /* гасим нижний паддинг .is-price (40px) */
  }
  .pricing-price-footer-item {
    padding: 14px 20px;
    font-size: 12px;
    line-height: 1.5;
    color: var(--cream-muted);
    border-right: 1px solid var(--cream-border);
    flex: 1;
    min-width: 200px;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .pricing-price-footer-item:last-child { border-right: none; }
  .pricing-price-footer-item:hover { background: var(--bg); color: var(--ink); }

  /* вторичная кнопка на тёмном фоне: контурная */
  .btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--bg);
    border: 1px solid var(--cream-border);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 32px;
    cursor: pointer;
    transition: border-color 0.3s ease, color 0.3s ease;
    white-space: nowrap;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  /* та же анимация, что у .format-floor__btn — быстрая прямая заливка вместо смены цвета рамки */
  .btn-secondary--swap { transition: background 0.12s, color 0.12s, border-color 0.12s; }
  .btn-secondary--swap:hover { background: var(--accent); color: var(--ink); border-color: var(--accent); }

  .pricing-active {
    position: relative;
    overflow: hidden;
    max-width: 70%;
    margin: 0 auto 24px;
    background: var(--cream-panel);
    border: 1px solid var(--cream-border);
    padding: 32px 40px;
    --ascii-dim: rgba(245,166,35,0.20);
    --ascii-bright: rgba(255,226,172,0.88);
  }
  .pricing-active__content { position: relative; z-index: 2; }
  .pricing-active__head { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .pricing-active__badge {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    background: transparent;
    border: 1px solid var(--accent);
    padding: 6px 12px;
    white-space: nowrap;
  }
  .pricing-active__title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 24px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    color: var(--bg);
    margin: 0 0 20px;
  }
  .pricing-active__cta { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .pricing-active__note { font-size: 14px; line-height: 1.6; font-weight: 700; color: var(--accent); }

  .pricing-active__list { list-style: none; margin: 0 0 24px; padding: 0; }
  .pricing-active__list li {
    font-size: 14px;
    line-height: 1.6;
    color: var(--white);
    border-left: 2px solid var(--accent);
    padding-left: 14px;
    margin-bottom: 14px;
  }
  .pricing-active__list li:last-child { margin-bottom: 0; }

  .pricing-group {
    max-width: 70%;
    background: var(--cream-panel);
    border: 1px solid var(--cream-border);
    margin: 0 auto 24px;
    padding: 32px 40px;
  }
  .pricing-group__text { max-width: 640px; margin-bottom: 20px; }
  .pricing-group__text p { font-size: 14px; line-height: 1.6; color: var(--bg); margin: 0; }
  .pricing-group__cta { display: flex; justify-content: flex-end; align-items: center; gap: 12px; flex-wrap: wrap; }

  .pricing-teams { border-top: 1px solid var(--cream-border); padding-top: 20px; margin-bottom: 24px; }
  .pricing-teams p { font-size: 13px; color: var(--cream-muted); margin: 0; }
  .pricing-teams a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); }
  .pricing-teams a:hover { color: var(--bg); border-color: var(--bg); }

  @media (max-width: 768px) {
    .pricing-section { padding: 48px 16px; }
    .pricing-main, .pricing-active, .pricing-group { max-width: 100%; }
    .pricing-main__head { padding-left: 20px; padding-right: 20px; }
    .pricing-value-list li { padding-left: 44px; padding-right: 20px; }
    .pricing-value-list li::before { left: 20px; }
