<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; border-radius: 0 !important; }
  
  :root {
    --bg: #f5f5f0;
    --ink: #0a0a0f;
    --accent: #f5a623;
    --ink10: rgba(10,10,15,0.10);
    --ink20: rgba(10,10,15,0.20);
    --ink40: rgba(10,10,15,0.40);
    --ink60: rgba(10,10,15,0.72);
    --ink05: rgba(10,10,15,0.05);
    /* инверсия для тёмных секций (кремовый с альфой) */
    --cream-border: rgba(245,245,240,0.12);
    --cream-muted: rgba(245,245,240,0.45);
    --cream-panel: rgba(245,245,240,0.05);
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'JetBrains Mono', 'SF Mono', 'Consolas', monospace;
    font-variant-numeric: tabular-nums;
    text-rendering: optimizeLegibility;
    max-width: 1440px;
    margin: 0 auto;
    overflow-x: hidden;
  }

  h1, h2, h3, .display {
    font-family: 'Roboto Condensed', 'Arial Narrow', Arial, sans-serif !important;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    text-rendering: optimizeLegibility;
    font-variant-numeric: tabular-nums;
  }

  /* NAV — приклеена к верху при скролле (особенно на мобилке) */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 48px;
    background: rgba(245,245,240,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--ink10);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 24px;
    max-width: 1440px;
    margin: 0 auto;
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  .nav-logo {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: color 0.15s;
  }
  .nav-logo:hover { color: var(--accent); }
  .nav-center {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 11px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50% !important;
    background: var(--accent);
    flex-shrink: 0;
    animation: navPulse 1.5s ease-in-out infinite;
  }
  @keyframes navPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245,166,35,0.6); }
    50%       { box-shadow: 0 0 0 5px rgba(245,166,35,0); }
  }
  .nav-announce {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .nav-announce-line1 {
    font-size: 10.5px;
    font-weight: 600;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
  }
  .nav-announce-line2 {
    font-size: 9px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
    white-space: nowrap;
  }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    align-self: stretch;
    justify-self: end;
    position: relative;
    overflow: hidden;
    padding: 0 28px;
    background: var(--accent);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    cursor: pointer;
    border: none;
    line-height: 1;
  }
  .nav-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }
  .nav-cta:hover::before { transform: translateX(0); }
  .nav-cta span { position: relative; z-index: 1; }
  .nav-cta:hover span { color: #f5f5f0; }
  .nav-right {
    display: flex;
    align-items: stretch;
    gap: 16px;
    justify-self: end;
    align-self: stretch;
  }
  .nav-social {
    width: 20px;
    background-color: var(--ink60);
    -webkit-mask: var(--icon) center / contain no-repeat;
    mask: var(--icon) center / contain no-repeat;
    transition: background-color 0.15s;
  }
  .nav-social:hover { background-color: var(--accent); }
  .pulse-dot {
    width: 7px; height: 7px;
    background: var(--accent);
    border-radius: 50% !important;
    animation: pulse 1.8s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  /* Левая часть навигации: лого + бургер */
  .nav-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  /* Бургер-меню — без окантовки и квадратика */
  .nav-burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    background: none;
    border: none;
    outline: none;
    box-shadow: none;
    cursor: pointer;
    position: relative;
    z-index: 101;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-burger:hover { background: transparent; }
  .nav-burger:focus { outline: none; box-shadow: none; }
  .nav-burger:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.is-open span:nth-child(2) { opacity: 0; }
  .nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .burger-overlay {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: rgba(10, 10, 15, 0.9);
    backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .burger-overlay.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .burger-panel {
    position: fixed;
    top: 48px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    padding: 24px 20px 32px;
    overflow: auto;
    display: flex;
    flex-direction: column;
    -webkit-overflow-scrolling: touch;
  }
  .burger-panel a,
  .burger-panel .burger-cta {
    display: block;
    font-family: 'Roboto Condensed', sans-serif !important;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--bg);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid rgba(245,245,240,0.15);
    transition: color 0.2s ease;
  }
  .burger-panel a:hover { color: var(--accent); }
  .burger-panel .burger-cta {
    margin-top: auto;
    padding-top: 24px;
    border-bottom: none;
    text-align: center;
    background: var(--accent);
    color: var(--ink);
    border-radius: 0;
    cursor: pointer;
    width: 100%;
    margin-left: 0;
    margin-right: 0;
  }
  .burger-panel .burger-cta:hover { opacity: 0.95; color: var(--ink); }

  /* SECTIONS */
  section { 
    padding: 80px 24px; 
    border-bottom: 1px solid var(--ink10);
    position: relative;
  }
  .section-grid {
    display: block;
    max-width: 1200px;
  }

  /* HERO — контент отступает от фиксированного навбара, без обрезки сверху */
  #hero {
    padding: 88px 24px 80px;
    padding-top: max(88px, 56px + 48px);
    border-bottom: 1px solid var(--ink10);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }
  .hero-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 24px;
  }
  .hero-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(56px, 8vw, 120px);
    line-height: 0.92;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    max-width: 1100px;
    margin-bottom: 40px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero-title .word { display: inline-block; opacity: 1; }
  .hero-accent { color: var(--accent); }
  .hero-sub {
    border-left: 2px solid var(--accent);
    padding-left: 24px;
    max-width: 640px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--ink60);
    margin-bottom: 56px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 480px;
    border: 1px solid var(--ink10);
  }
  .stat-box {
    padding: 24px 28px;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
    /* сюда добавить: */
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .stat-box:last-child { border-right: none; }
  .stat-num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 48px;
    line-height: 1;
    color: var(--accent);
    display: block;
    margin-bottom: 6px;
  }
  .stat-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink40);
  }

  /* CTA BUTTON */
  .cta-btn {
    display: inline-block;
    width: auto;
    max-width: max-content;
    position: relative;
    overflow: hidden;
    clip-path: inset(0);
    padding: 16px 40px;
    background: var(--accent);
    color: var(--ink);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    cursor: pointer;
    border: none;
  }
  .cta-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--ink);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }
  .cta-btn:hover::before { transform: translateX(0); }
  .cta-btn span { position: relative; z-index: 1; }
  .cta-btn:hover span { color: #f5f5f0; }

  /* ABOUT / LEGEND */
  .about-text {
    font-size: 16px;
    line-height: 1.8;
    color: var(--ink60);
    max-width: 720px;
    margin-bottom: 32px;
  }
  .about-text strong { color: var(--ink); font-weight: 600; }
  .bracket-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
    display: block;
  }

  /* FOR WHOM */
  .audience-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .audience-item {
    padding: 24px 28px;
    border-right: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .audience-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .audience-item.visible { opacity: 1; transform: translateY(0); }
  .audience-item:nth-child(even) { border-right: none; }
  .audience-item:nth-last-child(-n+2) { border-bottom: none; }
  .audience-num {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 32px;
    color: var(--ink20);
    margin-bottom: 8px;
  }
  .audience-text {
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink60);
  }

  /* WHAT YOU LEARN */
  .learn-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .learn-item {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
    border-bottom: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .learn-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .learn-item.visible { opacity: 1; transform: translateY(0); }
  .learn-item:nth-child(even) { border-right: none; }
  .learn-item:nth-last-child(-n+2) { border-bottom: none; }
  .learn-arrow {
    color: var(--accent);
    font-size: 18px;
    margin-bottom: 10px;
    display: block;
  }
  .learn-text {
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .learn-text strong { color: var(--ink); }

  /* OUTCOMES BANNER */
  .outcomes-banner {
    background: var(--ink);
    padding: 36px 48px;
    display: flex;
    align-items: center;
    gap: 48px;
    flex-wrap: wrap;
    max-width: 1200px;
  }
  .outcomes-banner-label {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 28px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .outcomes-banner-text {
    font-size: 15px;
    color: #f5f5f0;
    line-height: 1.6;
  }
  @media (max-width: 640px) {
    .outcomes-banner { padding: 28px 24px; gap: 16px; flex-direction: column; align-items: flex-start; }
  }

  /* ABOUT REDESIGN */
  .about-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--ink10);
    margin-bottom: 2px;
  }
  .about-compare-col {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
  }
  .about-compare-col:last-child { border-right: none; }
  .about-compare-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink40);
    margin-bottom: 16px;
    display: block;
  }
  .about-compare-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .about-compare-list li {
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink60);
    padding: 8px 0 8px 14px;
    border-bottom: 1px solid var(--ink05);
    position: relative;
  }
  .about-compare-list li:last-child { border-bottom: none; }
  .about-compare-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--ink20);
  }
  .about-compare-col:last-child .about-compare-label { color: var(--accent); }
  .about-compare-col:last-child .about-compare-list li::before {
    content: '→';
    color: var(--accent);
  }
  .about-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--ink10);
    margin-bottom: 2px;
  }
  .about-card {
    padding: 32px 32px;
    border-right: 1px solid var(--ink10);
    background: var(--ink05);
  }
  .about-card:last-child { border-right: none; }
  .about-card--dark { background: var(--ink); }
  .about-card-title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 22px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.0;
    margin-bottom: 16px;
    color: var(--ink);
  }
  .about-card--dark .about-card-title { color: var(--accent); }
  .about-card-text {
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink60);
  }
  .about-card--dark .about-card-text { color: rgba(245,245,240,0.55); }
  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--ink10);
  }
  .about-stat {
    padding: 28px 32px;
    border-right: 1px solid var(--ink10);
  }
  .about-stat:last-child { border-right: none; }
  .about-stat-num {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 40px;
    color: var(--accent);
    line-height: 1;
    display: block;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .about-stat-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink40);
    line-height: 1.5;
  }
  @media (max-width: 900px) {
    .about-compare,
    .about-cards { grid-template-columns: 1fr; }
    .about-compare-col { border-right: none; border-bottom: 1px solid var(--ink10); }
    .about-compare-col:last-child { border-bottom: none; }
    .about-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .about-card:last-child { border-bottom: none; }
    .about-stats { grid-template-columns: 1fr 1fr; }
    .about-stat:nth-child(2) { border-right: none; }
    .about-stat:nth-child(1),
    .about-stat:nth-child(2) { border-bottom: 1px solid var(--ink10); }
  }
  @media (max-width: 640px) {
    .about-stats { grid-template-columns: 1fr; }
    .about-stat { border-right: none; border-bottom: 1px solid var(--ink10); }
    .about-stat:last-child { border-bottom: none; }
  }

  /* CONTEXT */
  .context-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid rgba(245,245,240,0.12);
    margin-bottom: 32px;
  }
  .context-card {
    padding: 32px 28px;
    border-right: 1px solid var(--ink10);
  }
  .context-card:last-child { border-right: none; }
  .context-num {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 40px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }
  .context-title {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
  }
  .context-desc {
    font-size: 13px;
    color: var(--ink60);
    line-height: 1.7;
  }
  .context-cta-row {
    display: flex;
    align-items: center;
    gap: 32px;
    padding-top: 28px;
    flex-wrap: wrap;
  }
  .context-cta-text {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink60);
  }
  @media (max-width: 900px) {
    .context-grid { grid-template-columns: 1fr 1fr; }
    .context-card:nth-child(2) { border-right: none; }
    .context-card:nth-child(1),
    .context-card:nth-child(2) { border-bottom: 1px solid var(--ink10); }
  }
  @media (max-width: 640px) {
    .context-grid { grid-template-columns: 1fr; }
    .context-card { border-right: none; border-bottom: 1px solid var(--ink10); }
    .context-card:last-child { border-bottom: none; }
    .context-cta-row { flex-direction: column; align-items: flex-start; }
  }

  /* FORMAT MODAL */
  .format-floor {
    background: var(--bg);
    color: var(--ink);
    border: 1px solid var(--ink10);
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .format-floor__text { font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; line-height: 1.55; margin: 0; max-width: 80ch; color: var(--ink60); }
  .format-floor__btn { font-family: 'Roboto Condensed', sans-serif; font-weight: 900; text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.85rem; background: var(--ink); color: var(--bg); border: 1px solid var(--ink); border-radius: 0 !important; padding: 0.75rem 1.25rem; cursor: pointer; white-space: nowrap; transition: background 0.12s, color 0.12s; }
  .format-floor__btn:hover { background: var(--accent); color: var(--ink); }
  .format-facts {
    display: flex;
    flex: 1;
    min-width: 0;
  }
  .format-fact {
    flex: 1;
    padding: 0.25rem 0.875rem;
    border-right: 1px solid var(--ink10);
    min-width: 0;
  }
  .format-fact:first-child { padding-left: 0; }
  .format-fact:last-child { border-right: none; padding-right: 0; }
  .format-fact__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    display: block;
    margin-bottom: 5px;
  }
  .format-fact__value {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 400;
    font-size: 11px;
    line-height: 1.35;
    color: var(--ink);
    display: block;
  }
  @media (max-width: 900px) {
    .format-floor { flex-direction: column; align-items: stretch; }
    .format-facts { display: grid; grid-template-columns: 1fr 1fr; flex: none; }
    .format-fact { padding: 0.625rem 0; border-right: none; border-bottom: 1px solid var(--ink10); }
    .format-fact:nth-child(odd) { padding-right: 0.75rem; border-right: 1px solid var(--ink10); }
    .format-fact:last-child { grid-column: span 2; border-bottom: none; border-right: none; padding-right: 0; }
    .format-floor__btn { align-self: flex-start; }
  }
  @media (max-width: 640px) {
    .format-facts { grid-template-columns: 1fr; }
    .format-fact:nth-child(odd) { padding-right: 0; border-right: none; }
    .format-fact:last-child { grid-column: span 1; border-bottom: none; }
    .format-floor__btn { width: 100%; text-align: center; }
  }
  .format-modal { position: fixed; inset: 0; z-index: 999; display: flex; align-items: flex-start; justify-content: center; padding: 2rem 1rem; overflow-y: auto; }
  .format-modal[hidden] { display: none; }
  .format-modal__backdrop { position: fixed; inset: 0; background: rgba(10,10,15,0.66); }
  .format-modal__dialog { position: relative; background: var(--bg); color: var(--ink); border: 1px solid var(--ink); border-radius: 0 !important; width: 100%; max-width: 44rem; padding: 2rem; box-shadow: 12px 12px 0 var(--ink); }
  .format-modal__dialog:focus { outline: none; }
  .format-modal__head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; border-bottom: 1px solid var(--ink10); padding-bottom: 1rem; }
  .format-modal__eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.16em; color: #b9760f; margin: 0 0 0.5rem; }
  .format-modal__title { font-family: 'Roboto Condensed', sans-serif; font-weight: 900; text-transform: uppercase; font-size: clamp(1.4rem, 4vw, 2rem); line-height: 1.05; margin: 0; }
  .format-modal__x { font-family: 'JetBrains Mono', monospace; background: transparent; border: 1px solid var(--ink); border-radius: 0 !important; width: 2.25rem; height: 2.25rem; flex: 0 0 auto; cursor: pointer; font-size: 0.9rem; line-height: 2.25rem; text-align: center; transition: background 0.12s, color 0.12s; }
  .format-modal__x:hover { background: var(--ink); color: var(--bg); }
  .format-modal__lede { font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; line-height: 1.6; margin: 1.25rem 0 0; color: var(--ink60); }
  .format-block { margin-top: 2rem; }
  .format-block__h { font-family: 'Roboto Condensed', sans-serif; font-weight: 900; text-transform: uppercase; letter-spacing: 0.03em; font-size: 1rem; margin: 0 0 1rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--ink10); }
  .format-block__p, .format-block__total { font-family: 'JetBrains Mono', monospace; font-size: 0.88rem; line-height: 1.6; margin: 0 0 0.75rem; }
  .format-block__total { margin-top: 1rem; color: var(--ink40); font-size: 0.82rem; }
  .weekbar { display: flex; gap: 2px; margin-bottom: 1.25rem; height: 4.5rem; }
  .weekbar__seg { flex: var(--span); border: 1px solid var(--ink); border-radius: 0 !important; padding: 0.6rem 0.75rem; display: flex; flex-direction: column; justify-content: center; gap: 0.2rem; }
  .weekbar__seg--live { background: var(--ink); color: var(--bg); border-left: 4px solid var(--accent); }
  .weekbar__seg--practice { background: transparent; color: var(--ink40); border-style: dashed; }
  .weekbar__label { font-family: 'Roboto Condensed', sans-serif; font-weight: 900; text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.8rem; }
  .weekbar__time { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; }
  .loadtoggle { display: flex; border: 1px solid var(--ink); border-radius: 0 !important; margin-bottom: 1.25rem; }
  .loadtoggle__btn { flex: 1; font-family: 'Roboto Condensed', sans-serif; font-weight: 900; text-transform: uppercase; letter-spacing: 0.03em; font-size: 0.78rem; background: transparent; color: var(--ink); border: none; border-radius: 0 !important; padding: 0.7rem 0.5rem; cursor: pointer; transition: background 0.12s, color 0.12s; }
  .loadtoggle__btn + .loadtoggle__btn { border-left: 1px solid var(--ink); }
  .loadtoggle__btn.is-active { background: var(--ink); color: var(--bg); }
  .loadout { border-left: 4px solid var(--accent); padding-left: 1rem; margin-bottom: 1rem; }
  .loadout__hours { font-family: 'Roboto Condensed', sans-serif; font-weight: 900; font-size: clamp(2rem, 7vw, 3rem); line-height: 1; margin: 0; }
  .loadout__note { font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; line-height: 1.5; margin: 0.4rem 0 0; color: var(--ink40); }
  .format-callout { font-family: 'JetBrains Mono', monospace; font-size: 0.86rem; line-height: 1.6; border-left: 4px solid var(--accent); padding: 0.4rem 0 0.4rem 1rem; margin-bottom: 1rem; color: var(--ink60); }
  .format-callout:last-child { margin-bottom: 0; }
  /* сетка формата урока внутри модалки — уже 640px контента, 4 колонки не влезают */
  .format-modal .format-grid { grid-template-columns: repeat(2, 1fr); margin-top: 1.25rem; }
  .format-modal .format-item { padding: 24px; }
  .format-modal .format-title { font-size: 18px; }
  /* .js .format-item скрывает карточки для scroll-reveal — модалка не скроллится, показываем сразу */
  .js .format-modal .format-item { opacity: 1; transform: none; }
  @media (max-width: 560px) {
    .weekbar { height: auto; flex-direction: column; }
    .format-modal__dialog { box-shadow: 6px 6px 0 var(--ink); padding: 1.5rem; }
    .format-modal .format-grid { grid-template-columns: 1fr; }
  }
  /* CURRICULUM */
  .module-block {
    margin-bottom: 2px;
    border: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .module-block { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .module-block.visible { opacity: 1; transform: translateY(0); }
  .module-header {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    align-items: center;
    padding: 20px 24px;
    background: var(--ink05);
  }
  .module-num-badge {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 22px;
    color: var(--accent);
  }
  .module-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .module-meta {
    font-size: 10px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    margin-left: 16px;
  }
  .module-body {
    padding: 24px;
    border-top: 1px solid var(--ink10);
  }
  .lesson-row {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--ink10);
    font-size: 12px;
  }
  .lesson-row > div:last-child { min-width: 0; }
  .lesson-row:last-child { border-bottom: none; }
  .lesson-num-sm {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 20px;
    color: var(--ink20);
    line-height: 1;
  }
  .lesson-name {
    font-weight: 600;
    font-size: 14px;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .lesson-desc {
    font-size: 12px;
    color: var(--ink60);
    line-height: 1.6;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .lesson-name { overflow-wrap: break-word; word-break: break-word; }
  .lesson-concepts {
    margin-top: 8px;
    font-size: 10px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-left: 2px solid var(--accent);
    padding-left: 10px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .module-body { overflow-wrap: break-word; word-break: break-word; }
  .module-title { overflow-wrap: break-word; word-break: break-word; }
  .bracket-label { overflow-wrap: break-word; word-break: break-word; }

  /* FORMAT */
  .format-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--ink10);
  }
  .format-item {
    padding: 32px 28px;
    border-right: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .format-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .format-item.visible { opacity: 1; transform: translateY(0); }
  .format-item:last-child { border-right: none; }
  .format-icon {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
    display: block;
  }
  .format-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 22px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .format-desc {
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink60);
  }

  /* SECTION TITLES */
  .section-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: clamp(32px, 4vw, 56px);
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    margin-bottom: 40px;
  }

  /* FAQ */
  .faq-list { list-style: none; }
  .faq-item {
    padding: 24px 0;
    border-bottom: 1px solid var(--ink10);
    opacity: 1;
  }
  .js .faq-item { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .js .faq-item.visible { opacity: 1; transform: translateY(0); }
  .faq-item:last-child { border-bottom: none; }
  .faq-q {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 700;
    font-size: 16px;
    color: var(--ink);
    margin-bottom: 12px;
    line-height: 1.35;
    cursor: pointer;
    user-select: none;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .faq-q::after {
    content: '+';
    flex-shrink: 0;
    margin-left: 16px;
    font-size: 20px;
    line-height: 1.2;
    transition: transform 0.2s;
  }
  .faq-item.faq-open .faq-q::after { content: '−'; }
  .faq-a {
    font-size: 15px;
    line-height: 1.7;
    color: var(--ink60);
    display: none;
  }
  .faq-item.faq-open .faq-a { display: block; }
  .faq-a strong { color: var(--ink); }


  /* CTA BLOCK */
  .cta-block {
    background: var(--ink);
    color: var(--bg);
    padding: 80px 24px;
    text-align: center;
  }
  .cta-block .section-title { color: var(--bg); margin-bottom: 16px; }
  .cta-widget-wrap { margin-top: 32px; min-height: 60px; }
  /* Pricing grid inside dark CTA block */
  .cta-block .pricing-grid {
    border-color: rgba(245,245,240,0.12);
    margin: 40px auto 0;
  }
  .cta-block .pricing-card {
    background: rgba(245,245,240,0.06);
    border-right-color: rgba(245,245,240,0.12);
    text-align: left;
  }
  .cta-block .pricing-card-tier { color: rgba(245,245,240,0.45); }
  .cta-block .pricing-card-name { color: var(--bg); }
  .cta-block .pricing-price-label { color: rgba(245,245,240,0.45); }
  .cta-block .pricing-alt {
    color: rgba(245,245,240,0.45);
    border-top-color: rgba(245,245,240,0.12);
    border-bottom-color: rgba(245,245,240,0.12);
  }
  .cta-block .pricing-alt strong { color: var(--accent); font-weight: 700; }
  .cta-block .pricing-bullet { color: var(--bg); }
  .cta-block .pricing-bullet::before { color: var(--bg); }
  .pricing-card-btn { margin-top: auto; padding-top: 28px; }
  .referral-block {
    max-width: 1100px;
    margin: 40px auto 0;
    text-align: left;
    background: var(--ink);
    border: none;
    padding: 40px 36px;
  }
  .referral-title {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 26px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--bg);
    margin-bottom: 32px;
  }
  .referral-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid rgba(245,245,240,0.12);
    margin-bottom: 32px;
  }
  .referral-col {
    padding: 24px 28px;
    border-right: 1px solid rgba(245,245,240,0.12);
  }
  .referral-col:last-child { border-right: none; }
  .referral-col-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(245,245,240,0.45);
    margin-bottom: 12px;
  }
  .referral-col-value {
    font-family: 'Roboto Condensed', sans-serif !important;
    font-weight: 900;
    font-size: 44px;
    line-height: 1;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .referral-col-text {
    font-size: 12px;
    line-height: 1.6;
    color: var(--bg);
  }
  @media (max-width: 640px) {
    .cta-block .pricing-card { border-bottom-color: rgba(245,245,240,0.12); }
  }
  /* Модальное окно с виджетом заявки */
  .widget-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(8px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .widget-modal.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .widget-modal__box {
    position: relative;
    width: 100%;
    max-width: 640px;
    max-height: 90vh;
    overflow: auto;
    background: var(--bg);
    color: var(--ink);
    padding: 32px 24px;
    border: 1px solid var(--ink10);
  }
  .widget-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    font-size: 24px;
    line-height: 1;
    color: var(--ink60);
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .widget-modal__close:hover { color: var(--ink); }
  .widget-modal__body { min-height: 200px; }
  .widget-modal__body iframe { max-width: 100%; }

  @media (max-width: 768px) {
    .cta-btn {
      display: block;
      width: 100%;
      max-width: none;
      padding: 12px 20px;
      font-size: 11px;
      letter-spacing: 0.06em;
      white-space: normal;
      line-height: 1.3;
      text-align: center;
      word-break: break-word;
      overflow-wrap: break-word;
    }
    .widget-modal { padding: 12px 8px; align-items: flex-end; }
    .widget-modal__box {
      max-height: 92vh;
      max-height: 92dvh;
      padding: 48px 16px 24px;
      width: 100%;
      overflow: auto;
      -webkit-overflow-scrolling: touch;
    }
    .widget-modal__body {
      min-height: 180px;
      overflow: auto;
      max-width: 100%;
    }
    .widget-modal__body iframe { width: 100% !important; max-width: 100%; }
  }

  @media (max-width: 480px) {
    .cta-btn { padding: 10px 16px; font-size: 10px; }
  }

  .cta-subtitle {
    font-size: 14px;
    color: rgba(245,245,240,0.5);
    margin-bottom: 48px;
    line-height: 1.7;
  }

  /* FOOTER */
  footer {
    padding: 48px 24px 32px;
    border-top: 1px solid var(--ink10);
    font-size: 11px;
    color: var(--ink40);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }
  .footer-brand {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 900;
    font-size: 18px;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-bottom: 8px;
  }
  .footer-tagline {
    font-size: 10px;
    color: var(--ink40);
    letter-spacing: 0.12em;
  }
  .footer-links {
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
  }
  .footer-col-title {
    font-size: 9px;
    color: var(--ink40);
    letter-spacing: 0.2em;
    margin-bottom: 12px;
  }
  .footer-col a {
    display: block;
    color: var(--ink60);
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
