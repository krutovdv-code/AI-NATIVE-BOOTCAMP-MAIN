    <div class="widget-modal__body" id="widget-modal-body">
      <!-- Виджет подгружается при первом открытии модалки, чтобы не блокировать страницу -->
    </div>
  </div>
</div>

<script is:inline>
  // Модальное окно с виджетом заявки (виджет подгружаем при первом открытии — не блокирует страницу)
  const modal = document.getElementById('widget-modal');
  const widgetBody = document.getElementById('widget-modal-body');
  var loadedWidgetId = null;
  function openWidgetModal(widgetId) {
    if (!modal) return;
    if (widgetId && widgetId !== loadedWidgetId && widgetBody) {
      widgetBody.innerHTML = '';
      loadedWidgetId = widgetId;
      var s = document.createElement('script');
      s.setAttribute('ao-number', '3272');
      s.setAttribute('ao-widget-id', widgetId);
      s.setAttribute('ao-domain', 'content.scalingclub.ru');
      s.src = 'https://idx.xl.ru/site/widget/widget.min.js';
      s.async = true;
      widgetBody.appendChild(s);
    }
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeWidgetModal() {
    if (modal) {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  }
  document.querySelectorAll('.js-open-widget').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      openWidgetModal(btn.getAttribute('data-widget-id'));
    });
  });
  document.querySelectorAll('.js-close-widget').forEach(function(btn) {
    btn.addEventListener('click', closeWidgetModal);
  });
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeWidgetModal();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeWidgetModal();
    });
  }


  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        // Stagger children
        const children = e.target.querySelectorAll('.audience-item, .learn-item, .format-item, .faq-item');
        children.forEach((c, i) => {
          setTimeout(() => c.classList.add('visible'), i * 80);
        });
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal, .module-block').forEach(el => observer.observe(el));

  // Format modal
  (function() {
    var fModal = document.querySelector('[data-format-modal]');
    var fDialog = fModal && fModal.querySelector('.format-modal__dialog');
    var fOpenBtn = document.querySelector('[data-format-open]');
    var fCloseEls = fModal && fModal.querySelectorAll('[data-format-close]');
    var fLastFocused = null;
    function openFModal() {
      fLastFocused = document.activeElement;
      if (fModal) fModal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      if (fDialog) fDialog.focus();
      document.addEventListener('keydown', onFKeydown);
    }
    function closeFModal() {
      if (fModal) fModal.setAttribute('hidden', '');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onFKeydown);
      if (fLastFocused instanceof HTMLElement) fLastFocused.focus();
    }
    function onFKeydown(e) { if (e.key === 'Escape') closeFModal(); }
    if (fOpenBtn) fOpenBtn.addEventListener('click', openFModal);
    if (fCloseEls) fCloseEls.forEach(function(el) { el.addEventListener('click', closeFModal); });
    var FLOAD = {
      webinar: { hours: '2-3 часа', note: 'в неделю, до 4-6 часов в недели с двумя встречами' },
      full: { hours: '4-8 часов', note: 'в неделю, с практикой на своём проекте' }
    };
    var fToggleBtns = fModal && fModal.querySelectorAll('[data-load]');
    var fHoursEl = fModal && fModal.querySelector('[data-load-hours]');
    var fNoteEl = fModal && fModal.querySelector('[data-load-note]');
    if (fToggleBtns) fToggleBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        fToggleBtns.forEach(function(b) { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
        btn.classList.add('is-active');
        btn.setAttribute('aria-selected', 'true');
        var mode = btn.getAttribute('data-load');
        if (fHoursEl) fHoursEl.textContent = FLOAD[mode].hours;
        if (fNoteEl) fNoteEl.textContent = FLOAD[mode].note;
      });
    });
  })();

  // Lesson format modal
  (function() {
    var lModal = document.querySelector('[data-lesson-modal]');
    var lDialog = lModal && lModal.querySelector('.format-modal__dialog');
    var lOpenBtns = document.querySelectorAll('[data-lesson-open]');
    var lCloseEls = lModal && lModal.querySelectorAll('[data-lesson-close]');
    var lLastFocused = null;
    function openLModal() {
      lLastFocused = document.activeElement;
      if (lModal) lModal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      if (lDialog) lDialog.focus();
      document.addEventListener('keydown', onLKeydown);
    }
    function closeLModal() {
      if (lModal) lModal.setAttribute('hidden', '');
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onLKeydown);
      if (lLastFocused instanceof HTMLElement) lLastFocused.focus();
    }
    function onLKeydown(e) { if (e.key === 'Escape') closeLModal(); }
    lOpenBtns.forEach(function(btn) { btn.addEventListener('click', openLModal); });
    if (lCloseEls) lCloseEls.forEach(function(el) { el.addEventListener('click', closeLModal); });
  })();
</script>

