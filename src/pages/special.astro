  }
  .footer-col a:hover { color: var(--ink); }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    border-top: 1px solid var(--ink10);
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-requisites {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--ink10);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 40px;
  }
  .footer-requisites p {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--ink40);
